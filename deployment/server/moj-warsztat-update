#!/usr/bin/env bash
set -Eeuo pipefail

CONFIG=${MOJ_WARSZTAT_DEPLOY_CONFIG:-/etc/moj-warsztat/deploy.env}
[[ -f "$CONFIG" ]] || { echo "Brak konfiguracji: $CONFIG" >&2; exit 1; }
# shellcheck disable=SC1090
source "$CONFIG"

APP_DIR=${APP_DIR:-/opt/moj-warsztat}
IMAGE_TAG=${1:-${IMAGE_TAG:-stable}}
IMAGE_REPO=${IMAGE_REPO:?Ustaw IMAGE_REPO w $CONFIG}
HEALTH_URL=${HEALTH_URL:-http://127.0.0.1:3000/health}
HEALTH_RETRIES=${HEALTH_RETRIES:-30}
HEALTH_DELAY=${HEALTH_DELAY:-2}
CONTAINER=${CONTAINER:-moj-warsztat}
STATE=/var/lib/moj-warsztat/deploy-state.env
TARGET_IMAGE="${IMAGE_REPO}:${IMAGE_TAG}"
ROLLBACK_IMAGE="${IMAGE_REPO}:rollback-local"

cd "$APP_DIR"
[[ -f compose.prod.yml ]] || { echo "Brak $APP_DIR/compose.prod.yml" >&2; exit 1; }
[[ -f .env ]] || { echo "Brak $APP_DIR/.env" >&2; exit 1; }

mkdir -p /var/lib/moj-warsztat

echo "[1/5] Backup przed aktualizacją..."
/usr/local/sbin/moj-warsztat-backup >/dev/null

CURRENT_IMAGE_ID=$(docker inspect -f '{{.Image}}' "$CONTAINER" 2>/dev/null || true)
CURRENT_IMAGE_REF=$(docker inspect -f '{{.Config.Image}}' "$CONTAINER" 2>/dev/null || true)
if [[ -n "$CURRENT_IMAGE_ID" ]]; then
  docker image tag "$CURRENT_IMAGE_ID" "$ROLLBACK_IMAGE"
fi

cat > "$STATE" <<STATE
PREVIOUS_IMAGE_REF='$CURRENT_IMAGE_REF'
ROLLBACK_IMAGE='$ROLLBACK_IMAGE'
TARGET_IMAGE='$TARGET_IMAGE'
UPDATED_AT='$(date --iso-8601=seconds)'
STATE
chmod 600 "$STATE"

echo "[2/5] Pobieranie $TARGET_IMAGE..."
docker pull "$TARGET_IMAGE"

echo "[3/5] Uruchamianie nowej wersji..."
MOJ_WARSZTAT_IMAGE="$TARGET_IMAGE" docker compose --env-file .env -f compose.prod.yml up -d --no-build

echo "[4/5] Test zdrowia..."
OK=0
for ((i=1; i<=HEALTH_RETRIES; i++)); do
  if curl -fsS "$HEALTH_URL" >/tmp/moj-warsztat-health.json 2>/dev/null; then
    OK=1
    break
  fi
  sleep "$HEALTH_DELAY"
done

if [[ "$OK" != 1 ]]; then
  echo "Nowa wersja nie przeszła testu. Automatyczny rollback..." >&2
  if docker image inspect "$ROLLBACK_IMAGE" >/dev/null 2>&1; then
    MOJ_WARSZTAT_IMAGE="$ROLLBACK_IMAGE" docker compose --env-file .env -f compose.prod.yml up -d --no-build
    exit 2
  fi
  echo "Brak lokalnego obrazu rollback. Wymagana interwencja ręczna." >&2
  exit 3
fi

echo "[5/5] Gotowe."
cat /tmp/moj-warsztat-health.json
printf '\n'
