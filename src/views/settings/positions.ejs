<%- include('../partials/header') %>
<div class="page-head"><div><span class="eyebrow">Ustawienia</span><h1>Stanowiska</h1><p class="muted">Edytuj stanowiska pracowników i fizyczne stanowiska warsztatowe używane w kalendarzu.</p></div></div>
<div class="two-col">
<section class="card"><div class="card-head"><h2>Stanowiska pracowników</h2></div><form method="post" action="<%= basePath %>/settings/positions/employee" class="form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Nazwa<input name="name" required placeholder="np. Mechanik"></label><label>Opis<input name="description"></label><div class="form-actions span-2"><button class="button primary">Dodaj stanowisko</button></div></form><div class="table-wrap"><table class="data-table"><thead><tr><th>Nazwa</th><th>Opis</th><th>Status</th><th></th></tr></thead><tbody><% employeePositions.forEach(p=>{ %><tr><form method="post" action="<%= basePath %>/settings/positions/employee"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="id" value="<%= p.id %>"><td><input name="name" value="<%= p.name %>"></td><td><input name="description" value="<%= p.description||'' %>"></td><td><label class="checkbox"><input type="checkbox" name="active" value="1" <%= p.active?'checked':'' %>><span>Aktywne</span></label></td><td><button class="button small">Zapisz</button></td></form></tr><% }) %></tbody></table></div></section>
<section class="card"><div class="card-head"><h2>Stanowiska warsztatowe / kalendarz</h2></div><form method="post" action="<%= basePath %>/settings/positions/workshop" class="form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Nazwa<input name="name" required placeholder="np. Podnośnik 1"></label><label>Kolor<input name="color" type="color" value="#3f8efc"></label><div class="form-actions span-2"><button class="button primary">Dodaj stanowisko</button></div></form><div class="table-wrap"><table class="data-table"><thead><tr><th>Nazwa</th><th>Kolor</th><th>Status</th><th></th></tr></thead><tbody><% workshopStations.forEach(p=>{ %><tr><form method="post" action="<%= basePath %>/settings/positions/workshop"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="id" value="<%= p.id %>"><td><input name="name" value="<%= p.name %>"></td><td><input name="color" type="color" value="<%= p.color %>"></td><td><label class="checkbox"><input type="checkbox" name="active" value="1" <%= p.active?'checked':'' %>><span>Aktywne</span></label></td><td><button class="button small">Zapisz</button></td></form></tr><% }) %></tbody></table></div></section>
</div>
<%- include('../partials/footer') %>
