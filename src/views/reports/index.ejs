<%- include('../partials/header') %>
<div class="page-head"><div><h1>Raporty</h1><p class="muted">Zakres dat, klient, pojazd i wyszukiwanie po nazwie usługi lub części.</p></div></div>
<section class="card report-filter"><form method="get" action="<%= basePath %>/reports" class="report-filter-grid">
  <label>Od<input type="date" name="from" value="<%= from %>"></label><label>Do<input type="date" name="to" value="<%= to %>"></label>
  <label>Klient<select name="client_id" data-searchable-select><option value="">Wszyscy</option><% clients.forEach(c=>{ %><option value="<%= c.id %>" <%= String(filters.client_id||'')===String(c.id)?'selected':'' %>><%= c.name %></option><% }) %></select></label>
  <label>Pojazd<select name="vehicle_id" data-searchable-select><option value="">Wszystkie</option><% vehicles.forEach(v=>{ %><option value="<%= v.id %>" <%= String(filters.vehicle_id||'')===String(v.id)?'selected':'' %>><%= v.registration||'bez rej.' %> · <%= v.make||'' %> <%= v.model||'' %></option><% }) %></select></label>
  <label class="span-2">Usługa / część<input name="service" value="<%= filters.service||'' %>" placeholder="np. wymiana oleju, klocki"></label>
  <div class="form-actions span-2"><button class="button primary" type="submit">Pokaż raport</button><a class="button" target="_blank" href="<%= basePath %>/reports/print?from=<%= encodeURIComponent(from) %>&to=<%= encodeURIComponent(to) %>&client_id=<%= filters.client_id||'' %>&vehicle_id=<%= filters.vehicle_id||'' %>&service=<%= encodeURIComponent(filters.service||'') %>">Drukuj / nowe okno</a><a class="button" target="_blank" href="<%= basePath %>/reports/pdf?from=<%= encodeURIComponent(from) %>&to=<%= encodeURIComponent(to) %>&client_id=<%= filters.client_id||'' %>&vehicle_id=<%= filters.vehicle_id||'' %>&service=<%= encodeURIComponent(filters.service||'') %>">PDF</a><a class="button success" href="<%= basePath %>/reports/excel?from=<%= encodeURIComponent(from) %>&to=<%= encodeURIComponent(to) %>&client_id=<%= filters.client_id||'' %>&vehicle_id=<%= filters.vehicle_id||'' %>&service=<%= encodeURIComponent(filters.service||'') %>">Pobierz Excel</a></div>
</form></section>
<div class="metric-grid four"><div class="metric-card"><span>Sprzedaż netto</span><strong><%= pln(revenue.net) %></strong><small>Brutto: <%= pln(revenue.gross) %></small></div><div class="metric-card"><span>Marża zleceń netto</span><strong><%= pln(orderProfit.sales_net-orderProfit.cost_net) %></strong><small>Sprzedaż <%= pln(orderProfit.sales_net) %> · koszt <%= pln(orderProfit.cost_net) %></small></div><div class="metric-card"><span>Zakupy netto</span><strong><%= pln(purchases.net) %></strong><small>Kasa — rozchody: <%= pln(cash.expense) %></small></div><div class="metric-card"><span>Koszt miesięczny pracowników</span><strong><%= pln(employeeMonthlyCost) %></strong><small>Widoczny dla użytkowników z dostępem do raportów.</small></div></div>
<section class="card"><div class="card-head"><h2>Miesięczne przychody i rozchody</h2></div><div class="table-wrap"><table class="data-table"><thead><tr><th>Miesiąc</th><th class="right">Sprzedaż brutto</th><th class="right">Zakupy netto</th><th class="right">Wpływy kasa</th><th class="right">Wydatki kasa</th><th class="right">Bilans operacyjny</th></tr></thead><tbody><% monthly.forEach(r=>{ const balance=Number(r.invoice_gross||0)+Number(r.cash_income||0)-Number(r.purchase_net||0)-Number(r.cash_expense||0); %><tr><td><strong><%= r.month %></strong></td><td class="right"><%= pln(r.invoice_gross) %></td><td class="right"><%= pln(r.purchase_net) %></td><td class="right"><%= pln(r.cash_income) %></td><td class="right"><%= pln(r.cash_expense) %></td><td class="right"><strong><%= pln(balance) %></strong></td></tr><% }) %></tbody></table></div></section>
<section class="card"><div class="card-head"><h2>Rozliczenie pracowników</h2><span class="muted">Szacunkowo: zakończone godziny z zadań × stawka RBH × prowizja</span></div><div class="table-wrap"><table class="data-table"><thead><tr><th>Pracownik</th><th class="right">Zakończone godziny</th><th class="right">Prowizja %</th><th class="right">Prowizja szac.</th><th class="right">Koszt mies.</th></tr></thead><tbody><% staffSettlement.forEach(r=>{ %><tr><td><strong><%= r.name %></strong></td><td class="right"><%= r.completed_hours %> h</td><td class="right"><%= r.commission_percent||0 %>%</td><td class="right"><%= pln(r.commission_value) %></td><td class="right"><%= pln(r.monthly_cost||0) %></td></tr><% }) %></tbody></table></div></section>
<div class="two-col"><section class="card"><div class="card-head"><h2>Statusy zleceń</h2></div><table><thead><tr><th>Status</th><th class="right">Liczba</th></tr></thead><tbody><% orderStatus.forEach(r=>{ %><tr><td><%= label('order',r.status) %></td><td class="right"><strong><%= r.count %></strong></td></tr><% }) %></tbody></table><% if(!orderStatus.length){ %><p class="muted">Brak zleceń w wybranym zakresie.</p><% } %></section><section class="card"><div class="card-head"><h2>Niski stan magazynowy</h2></div><table><thead><tr><th>Towar</th><th class="right">Stan / minimum</th></tr></thead><tbody><% lowStock.forEach(p=>{ %><tr><td><%= p.name %></td><td class="right"><strong><%= p.stock_qty %> / <%= p.min_stock %></strong></td></tr><% }) %></tbody></table><% if(!lowStock.length){ %><p class="muted">Brak ostrzeżeń magazynowych.</p><% } %></section></div>
<section class="card"><div class="card-head"><h2>Faktury w zakresie <%= from %> - <%= to %></h2></div><div class="table-wrap"><table><thead><tr><th>Numer</th><th>Data</th><th>Klient</th><th>Pojazd</th><th class="right">Netto</th><th class="right">VAT</th><th class="right">Brutto</th><th>Status</th></tr></thead><tbody><% invoices.forEach(i=>{ %><tr><td><strong><%= i.number %></strong></td><td><%= formatDate(i.issue_date) %></td><td><%= i.client_name||'Bez klienta' %></td><td><%= [i.registration,i.make,i.model].filter(Boolean).join(' ')||'—' %></td><td class="right"><%= pln(i.net) %></td><td class="right"><%= pln(i.vat) %></td><td class="right"><strong><%= pln(i.gross) %></strong></td><td><%= label('invoice',i.status) %></td></tr><% }) %></tbody></table></div><% if(!invoices.length){ %><p class="muted">Brak faktur w wybranym zakresie.</p><% } %></section>
<%- include('../partials/footer') %>
