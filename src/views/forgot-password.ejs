<%- include('partials/header') %>
<section class="login-card">
  <div class="brand large"><span class="brand-mark">MW</span><span><%= appName %></span></div>
  <h1>Nie pamiętam hasła</h1>
  <p class="muted">Podaj e-mail użytkownika. Link do ustawienia nowego hasła jest ważny przez 60 minut.</p>
  <form method="post" action="<%= basePath %>/forgot-password" class="stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>E-mail<input type="email" name="email" required autofocus autocomplete="email"></label>
    <button class="button primary full" type="submit">Wyślij link</button>
    <a class="login-help" href="<%= basePath %>/login">Wróć do logowania</a>
  </form>
</section>
<%- include('partials/footer') %>
