<%- include('../partials/header') %>
<% const isEdit=Boolean(invoice.id); const invoiceRows = items && items.length ? items : [{description:'',quantity:1,unit:'szt.',unit_price_net:0,vat_rate:23,discount_percent:0}]; %>
<div class="page-head"><div><div class="eyebrow"><%= invoice.document_type==='correction'?'Korekta':invoice.document_type==='invoice_receipt'?'Faktura do paragonu':'Faktura VAT' %></div><h1><%= title %></h1><p class="muted">Najpierw edytujesz szkic. Dokument zostaje wystawiony dopiero po kliknięciu „Wystaw fakturę”.</p></div><div class="actions"><% if(isEdit){ %><a class="button" href="<%= basePath %>/invoices/<%= invoice.id %>">Podgląd</a><% } %><a class="button" href="<%= basePath %>/invoices">Anuluj</a></div></div>
<form class="stack" method="post" action="<%= basePath %><%= action %>" id="invoice-form" data-invoice-form><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="document_type" value="<%= invoice.document_type||'invoice' %>"><input type="hidden" name="corrected_invoice_id" value="<%= invoice.corrected_invoice_id||'' %>"><input type="hidden" name="work_order_id" value="<%= invoice.work_order_id||'' %>">
<section class="card"><div class="form-grid three"><% if(isEdit){ %><label>Numer dokumentu<input name="number" required value="<%= invoice.number %>"></label><% } %><label class="<%= isEdit?'span-2':'span-3' %>">Klient<select name="client_id" required data-searchable-select><option value="">Wybierz klienta</option><% clients.forEach(c=>{ %><option value="<%= c.id %>" <%= String(invoice.client_id||'')===String(c.id)?'selected':'' %>><%= c.name %><%= c.nip?' · '+c.nip:'' %></option><% }) %></select></label><label>Data wystawienia<input name="issue_date" type="date" required value="<%= invoice.issue_date||'' %>" data-invoice-issue-date></label><label>Data sprzedaży<input name="sale_date" type="date" required value="<%= invoice.sale_date||'' %>"></label><label>Ilość dni do płatności<input name="payment_days" type="number" min="0" max="365" step="1" value="<%= invoice.payment_days==null?7:invoice.payment_days %>" data-payment-days></label><label>Termin płatności<input name="due_date" type="date" required value="<%= invoice.due_date||'' %>" data-invoice-due-date readonly></label><label>Metoda płatności<select name="payment_method" data-payment-method><option value="transfer" <%= invoice.payment_method==='transfer'?'selected':'' %>>Przelew</option><option value="cash" <%= invoice.payment_method==='cash'?'selected':'' %>>Gotówka</option><option value="card" <%= invoice.payment_method==='card'?'selected':'' %>>Karta</option></select></label><% if(invoice.document_type==='invoice_receipt'){ %><label class="span-2">Numer paragonu<input name="receipt_number" required value="<%= invoice.receipt_number||'' %>" placeholder="Wpisz numer paragonu ręcznie"></label><% } else { %><input type="hidden" name="receipt_number" value="<%= invoice.receipt_number||'' %>"><% } %><label class="span-3">Uwagi<textarea name="notes" rows="2"><%= invoice.notes||'' %></textarea></label></div></section>
<% if(isEdit){ %><section class="data-panel"><div class="toolbar" style="padding:9px"><span class="muted">Pierwszy pusty wiersz jest zawsze gotowy do edycji. Rabat ustawiasz osobno dla każdej pozycji.</span><div class="toolbar-right"><button class="button primary" type="button" data-add-invoice-row>＋ Dodaj pozycję</button></div></div><div class="table-wrap"><table class="data-table editable-lines" id="invoice-items-table"><thead><tr><th>Opis</th><th>Ilość</th><th>J.m.</th><th>Cena netto</th><th>Rabat %</th><th>VAT %</th><th></th></tr></thead><tbody><% invoiceRows.forEach(i=>{ %><tr><td><input name="item_description" value="<%= i.description||'' %>" list="invoice-suggestions" placeholder="Nazwa towaru lub usługi"></td><td><input name="item_quantity" type="number" step="0.01" value="<%= i.quantity==null?1:i.quantity %>"></td><td><input name="item_unit" value="<%= i.unit||'szt.' %>"></td><td><input name="item_price" type="number" step="0.01" value="<%= i.unit_price_net==null?0:i.unit_price_net %>"></td><td><input name="item_discount" type="number" min="0" max="100" step="0.01" value="<%= i.discount_percent||0 %>"></td><td><input name="item_vat" type="number" step="1" value="<%= i.vat_rate==null?23:i.vat_rate %>"></td><td><button class="delete-button" type="button" data-remove-row>×</button></td></tr><% }) %></tbody></table></div></section><div class="actions"><button class="button primary" type="submit">Zapisz szkic</button></div></form><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/issue" onsubmit="return confirm('Wystawić fakturę? Jeżeli faktura powstała ze zlecenia, zlecenie zostanie oznaczone jako zakończone.')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button success" type="submit">✓ Wystaw fakturę</button></form><% } else { %><div class="actions"><button class="button primary" type="submit">Utwórz szkic i przejdź do pozycji</button></div></form><% } %>
<template id="invoice-row-template"><tr><td><input name="item_description" list="invoice-suggestions" placeholder="Nazwa towaru lub usługi"></td><td><input name="item_quantity" type="number" step="0.01" value="1"></td><td><input name="item_unit" value="szt."></td><td><input name="item_price" type="number" step="0.01" value="0"></td><td><input name="item_discount" type="number" min="0" max="100" step="0.01" value="0"></td><td><input name="item_vat" type="number" step="1" value="23"></td><td><button class="delete-button" type="button" data-remove-row>×</button></td></tr></template>
<datalist id="invoice-suggestions"><% suggestions.forEach(v=>{ %><option value="<%= v %>"><% }) %></datalist>
<%- include('../partials/footer') %>
