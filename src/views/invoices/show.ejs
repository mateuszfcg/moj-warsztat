<%- include('../partials/header') %>
<div class="page-head"><div><div class="eyebrow">Faktura</div><h1><%= invoice.number %></h1><p class="muted"><%= invoice.client_name %> · <%= formatDate(invoice.issue_date) %></p></div><div class="actions"><a class="button" href="<%= basePath %>/invoices/<%= invoice.id %>/pdf">Pobierz PDF</a><% if (invoice.work_order_id) { %><a class="button" href="<%= basePath %>/orders/<%= invoice.work_order_id %>">Zlecenie</a><% } %></div></div>
<div class="invoice-summary"><span class="badge status-<%= invoice.status %>"><%= invoice.status %></span><span>Do zapłaty: <strong><%= pln(totals.gross) %></strong></span><span>KSeF: <strong><%= invoice.ksef_status %></strong></span></div>
<div class="two-col"><section class="card details"><h2>Dane faktury</h2><dl><dt>Data wystawienia</dt><dd><%= formatDate(invoice.issue_date) %></dd><dt>Data sprzedaży</dt><dd><%= formatDate(invoice.sale_date) %></dd><dt>Termin płatności</dt><dd><%= formatDate(invoice.due_date) %></dd><dt>Metoda</dt><dd><%= invoice.payment_method %></dd><dt>Nabywca</dt><dd><%= invoice.client_name %></dd><dt>NIP</dt><dd><%= invoice.client_nip || '—' %></dd><dt>Adres</dt><dd><%= invoice.client_address || '—' %></dd></dl></section>
<section class="card"><h2>Operacje</h2><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/status" class="inline-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><select name="status"><% ['issued','sent','paid','cancelled'].forEach(s => { %><option <%= invoice.status === s ? 'selected' : '' %>><%= s %></option><% }) %></select><button class="button" type="submit">Zmień status</button></form><hr><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/email" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Adres e-mail<input name="to" type="email" value="<%= invoice.client_email || '' %>"></label><button class="button" type="submit" <%= !smtpConfigured ? 'disabled title="Skonfiguruj SMTP w .env"' : '' %>>Wyślij PDF e-mailem</button><% if (!smtpConfigured) { %><small class="muted">SMTP nie jest skonfigurowane.</small><% } %></form></section></div>
<section class="card"><h2>Pozycje</h2><div class="table-wrap"><table><thead><tr><th>Opis</th><th>Ilość</th><th>Netto</th><th>VAT</th><th>Brutto</th></tr></thead><tbody><% items.forEach(item => { const t=lineTotals(item); %><tr><td><%= item.description %></td><td><%= item.quantity %> <%= item.unit %></td><td><%= pln(t.net) %></td><td><%= item.vat_rate %>% / <%= pln(t.vat) %></td><td><strong><%= pln(t.gross) %></strong></td></tr><% }) %></tbody><tfoot><tr><th colspan="2">Razem</th><th><%= pln(totals.net) %></th><th><%= pln(totals.vat) %></th><th><%= pln(totals.gross) %></th></tr></tfoot></table></div></section>
<section class="card"><div class="card-head"><div><h2>KSeF</h2><p class="muted"><%= ksefStatus.message %></p></div><span class="badge"><%= ksefStatus.mode %></span></div><dl class="compact-dl"><dt>Status</dt><dd><%= invoice.ksef_status %></dd><dt>Numer KSeF</dt><dd class="mono"><%= invoice.ksef_number || '—' %></dd><dt>Referencja</dt><dd class="mono"><%= invoice.ksef_reference || '—' %></dd></dl><div class="actions"><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/ksef"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button primary" type="submit">Dodaj do kolejki KSeF</button></form><form method="post" action="<%= basePath %>/ksef/process"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button" type="submit">Przetwórz kolejkę</button></form></div><% if (jobs.length) { %><div class="table-wrap"><table><thead><tr><th>Data</th><th>Status</th><th>Referencja</th><th>Błąd</th></tr></thead><tbody><% jobs.forEach(j => { %><tr><td><%= formatDate(j.created_at) %></td><td><span class="badge status-<%= j.status %>"><%= j.status %></span></td><td class="mono"><%= j.reference || '—' %></td><td><%= j.error || '—' %></td></tr><% }) %></tbody></table></div><% } %></section>
<%- include('../partials/footer') %>
