<%- include('../partials/header') %>
<% const statusLabels={draft:'Nowe zlecenie',estimate:'Wycena',approved:'Zaakceptowane',in_progress:'W trakcie naprawy',ready:'Gotowy do odbioru',completed:'Zakończone',cancelled:'Anulowane'}; const serviceItems=items.filter(i=>['labor','service'].includes(i.type)); const partItems=items.filter(i=>!['labor','service'].includes(i.type)); %>
<div class="order-head">
  <div><div class="eyebrow">Zlecenie / wycena</div><h1><%= order.number %></h1><div class="muted"><%= order.client_name||'Bez klienta' %> · <%= order.vehicle_id?(order.registration||'bez rejestracji'):'Bez pojazdu' %> · <%= order.make||'' %> <%= order.model||'' %></div></div>
  <span class="status-badge status-<%= order.status %>"><%= statusLabels[order.status]||order.status %></span><div class="spacer"></div>
  <div class="price-toggle"><a class="<%= priceMode==='net'?'active':'' %>" href="?price=net">NETTO</a><a class="<%= priceMode==='gross'?'active':'' %>" href="?price=gross">BRUTTO</a></div>
  <button class="button" type="button" onclick="window.print()">Drukuj</button><a class="button" href="<%= basePath %>/orders/<%= order.id %>/edit">Edytuj</a>
  <% if(!invoice){ %><form method="post" action="<%= basePath %>/orders/<%= order.id %>/invoice"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button primary" type="submit" <%= !order.client_id?'disabled title="Najpierw przypisz klienta"':'' %>>Wystaw fakturę</button></form><% }else{ %><a class="button primary" href="<%= basePath %>/invoices/<%= invoice.id %><%= invoice.status==='draft'?'/edit':'' %>"><%= invoice.status==='draft'?'Edytuj szkic FV':invoice.number %></a><% } %>
</div>
<div class="summary-strip"><span>Przebieg: <strong><%= order.mileage_in?order.mileage_in+' km':'—' %></strong></span><span>Paliwo: <strong><%= order.fuel_level||'—' %></strong></span><span>Przyjęcie: <strong><%= order.scheduled_for?formatDate(order.scheduled_for):'—' %></strong></span><span>Akceptacja: <strong><%= order.accepted_at?formatDate(order.accepted_at):'nie' %></strong></span><span class="spacer"></span><span>Wartość: <strong><%= pln(priceMode==='gross'?totals.gross:totals.net) %></strong></span></div>
<div class="detail-grid"><section class="card"><div class="card-head"><h2>Zlecenie i pojazd</h2></div><dl class="compact-dl"><dt>Zgłoszenie</dt><dd class="pre"><%= order.complaint||'—' %></dd><dt>Diagnoza</dt><dd class="pre"><%= order.diagnosis||'—' %></dd><dt>Notatki</dt><dd class="pre"><%= order.notes||'—' %></dd><dt>VIN</dt><dd class="mono"><%= order.vin||'—' %></dd><dt>Silnik</dt><dd><%= order.engine||'—' %></dd></dl></section><section class="card screen-only"><div class="card-head"><h2>Akceptacja kosztorysu</h2></div><p class="muted small">Klient zobaczy osobny, estetyczny widok kosztorysu. Ten link nie pojawia się na wydruku.</p><div style="display:flex;gap:7px"><input readonly value="<%= acceptanceUrl %>" id="acceptance-url"><button class="button" type="button" data-copy="#acceptance-url">Kopiuj</button></div><div class="actions" style="margin-top:10px"><a class="button small" target="_blank" href="<%= basePath %>/accept/<%= order.acceptance_token %>">Podgląd klienta ↗</a></div></section></div>

<section class="data-panel order-items" style="margin-bottom:14px">
  <div class="toolbar" style="padding:9px;margin:0;border-bottom:1px solid var(--line)"><strong>Pozycje zlecenia</strong><div class="toolbar-right"><span>Razem: <strong><%= pln(priceMode==='gross'?totals.gross:totals.net) %></strong></span></div></div>
  <form method="post" action="<%= basePath %>/orders/<%= order.id %>/items" class="inline-lines-form screen-only">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="line-form-toolbar"><span>Dodaj pozycje bez otwierania osobnego okna</span><label>Ceny <select name="input_price_mode"><option value="net" <%= priceMode==='net'?'selected':'' %>>netto</option><option value="gross" <%= priceMode==='gross'?'selected':'' %>>brutto</option></select></label></div>
    <div class="table-wrap"><table class="data-table editable-lines"><thead><tr><th>Typ</th><th>Opis</th><th>Ilość / RBH</th><th>J.m.</th><th>Cena</th><th>Rabat %</th><th>VAT</th><th>Koszt netto</th><th></th></tr></thead><tbody id="order-new-lines"><tr><td><select name="type"><option value="service">Usługa</option><option value="labor">Roboczogodzina</option><option value="part">Część</option><option value="material">Materiał</option></select></td><td><input name="description" list="service-suggestions" placeholder="Zacznij wpisywać nazwę"></td><td><input name="quantity" type="number" step="0.05" min="0.01" value="1"></td><td><input name="unit" value="szt."></td><td><input name="price_input" type="number" step="0.01" min="0" value="0"></td><td><input name="discount_percent" type="number" step="0.01" min="0" max="100" value="0"></td><td><input name="vat_rate" type="number" value="23"></td><td><input name="cost_net" type="number" step="0.01" min="0" value="0"></td><td><button class="delete-button" type="button" data-remove-row>×</button></td></tr></tbody></table></div>
    <div class="form-actions"><button class="button" type="button" data-add-line-row="#order-new-lines" data-line-template="#order-line-template">＋ Dodaj kolejną pozycję</button><button class="button primary" type="submit">Zapisz pozycje</button></div>
  </form>
  <div class="section-table-title">Usługi i robocizna</div><div class="table-wrap"><table class="data-table"><thead><tr><th>Typ</th><th>Opis</th><th>Ilość</th><th class="right">Cena jedn.</th><th>Rabat</th><th class="right">Wartość</th><th>VAT</th><th></th></tr></thead><tbody><% serviceItems.forEach(item=>{ const t=lineTotals(item); const unitGross=Number(item.unit_price_net)*(1+Number(item.vat_rate)/100); %><tr><td><%= item.type==='labor'?'RBH':'Usługa' %></td><td><%= item.description %></td><td><%= item.quantity %> <%= item.unit %></td><td class="right"><%= pln(priceMode==='gross'?unitGross:item.unit_price_net) %></td><td><%= item.discount_percent||0 %>%</td><td class="right"><%= pln(priceMode==='gross'?t.gross:t.net) %></td><td><%= item.vat_rate %>%</td><td><form method="post" action="<%= basePath %>/orders/<%= order.id %>/items/<%= item.id %>/delete"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="delete-button">×</button></form></td></tr><% }) %></tbody></table></div><% if(!serviceItems.length){ %><div class="empty compact">Brak usług.</div><% } %>
  <div class="section-table-title">Części i materiały</div><div class="table-wrap"><table class="data-table"><thead><tr><th>Typ</th><th>Opis</th><th>Ilość</th><th class="right">Cena jedn.</th><th>Rabat</th><th class="right">Wartość</th><th>VAT</th><th></th></tr></thead><tbody><% partItems.forEach(item=>{ const t=lineTotals(item); const unitGross=Number(item.unit_price_net)*(1+Number(item.vat_rate)/100); %><tr><td><%= item.type==='part'?'Część':'Materiał' %></td><td><%= item.description %></td><td><%= item.quantity %> <%= item.unit %></td><td class="right"><%= pln(priceMode==='gross'?unitGross:item.unit_price_net) %></td><td><%= item.discount_percent||0 %>%</td><td class="right"><%= pln(priceMode==='gross'?t.gross:t.net) %></td><td><%= item.vat_rate %>%</td><td><form method="post" action="<%= basePath %>/orders/<%= order.id %>/items/<%= item.id %>/delete"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="delete-button">×</button></form></td></tr><% }) %></tbody></table></div><% if(!partItems.length){ %><div class="empty compact">Brak części i materiałów.</div><% } %>
</section>

<div class="two-col"><section class="card"><div class="card-head"><h2>Protokoły</h2><div class="actions"><% if(settings.intake_protocol_enabled){ %><button class="button small" type="button" data-open-modal="intake-modal">Przyjęcie</button><% } %><button class="button small" type="button" data-open-modal="additional-modal">Dodatkowe koszty</button><% if(settings.release_protocol_enabled){ %><button class="button small" type="button" data-open-modal="release-modal">Wydanie</button><% } %></div></div><% if(protocols.length){ %><div class="table-wrap"><table class="data-table"><thead><tr><th>Dokument</th><th>Data</th><th>Wersja</th><th></th></tr></thead><tbody><% protocols.forEach(p=>{ %><tr><td><strong><%= p.number||'—' %></strong><small><%= p.type==='release'?'Protokół wydania':p.type==='additional_costs'?'Dodatkowe koszty':'Protokół przyjęcia' %></small></td><td><%= formatDate(p.updated_at||p.created_at) %></td><td>v<%= p.version||1 %></td><td class="right"><div class="actions"><a class="button small" href="<%= basePath %>/protocols/<%= p.id %>/edit">Edytuj</a><a class="button small" target="_blank" href="<%= basePath %>/protocols/<%= p.id %>/pdf">Drukuj</a><form class="inline" method="post" action="<%= basePath %>/protocols/<%= p.id %>/delete" onsubmit="return confirm('Usunąć protokół? Tej operacji nie można cofnąć.')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button small danger">Usuń</button></form></div></td></tr><% }) %></tbody></table></div><% }else{ %><p class="muted small">Nie utworzono jeszcze protokołów.</p><% } %></section><section class="card"><div class="card-head"><h2>Zdjęcia i dokumenty</h2></div><form method="post" action="<%= basePath %>/orders/<%= order.id %>/attachments" enctype="multipart/form-data" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="file" name="files" multiple accept="image/jpeg,image/png,image/webp,application/pdf"><button class="button" type="submit">Dodaj pliki</button></form><div class="attachment-grid" style="margin-top:10px"><% attachments.forEach(a=>{ %><a href="<%= basePath %>/uploads/<%= a.filename %>" target="_blank" class="attachment"><% if(a.mime_type.startsWith('image/')){ %><img src="<%= basePath %>/uploads/<%= a.filename %>" alt=""><% }else{ %><div class="file-icon">PDF</div><% } %><span><%= a.original_name %></span></a><% }) %></div></section></div>

<datalist id="service-suggestions"><% suggestions.service.forEach(v=>{ %><option value="<%= v %>"><% }) %></datalist><datalist id="part-suggestions"><% suggestions.part.forEach(v=>{ %><option value="<%= v %>"><% }) %></datalist><datalist id="material-suggestions"><% suggestions.material.forEach(v=>{ %><option value="<%= v %>"><% }) %></datalist>
<template id="order-line-template"><tr><td><select name="type"><option value="service">Usługa</option><option value="labor">Roboczogodzina</option><option value="part">Część</option><option value="material">Materiał</option></select></td><td><input name="description" list="service-suggestions" placeholder="Zacznij wpisywać nazwę"></td><td><input name="quantity" type="number" step="0.05" min="0.01" value="1"></td><td><input name="unit" value="szt."></td><td><input name="price_input" type="number" step="0.01" min="0" value="0"></td><td><input name="discount_percent" type="number" step="0.01" min="0" max="100" value="0"></td><td><input name="vat_rate" type="number" value="23"></td><td><input name="cost_net" type="number" step="0.01" min="0" value="0"></td><td><button class="delete-button" type="button" data-remove-row>×</button></td></tr></template>

<div class="modal" id="intake-modal" hidden><form class="modal-card wide" method="post" action="<%= basePath %>/orders/<%= order.id %>/protocols"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="type" value="intake"><div class="modal-head"><h2>Protokół przyjęcia</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid three"><label>Przebieg [km]<input name="mileage" type="number" min="0" value="<%= order.mileage_in||'' %>"></label><label>Stan paliwa<select name="fuel_level"><option value="">Wybierz</option><option>Rezerwa</option><option>1/4</option><option>1/2</option><option>3/4</option><option>Pełny</option></select></label><label>Stan pojazdu<select name="vehicle_condition"><option value="">Wybierz stan</option><option>Bardzo dobry</option><option>Dobry</option><option>Normalne ślady użytkowania</option><option>Liczne zarysowania</option><option>Wgniecenia</option><option>Uszkodzenia lakieru</option><option>Uszkodzenia szyb</option><option>Uszkodzenia felg</option><option>Kontrolki ostrzegawcze</option><option>Pojazd niesprawny</option><option>Dostarczony lawetą</option></select></label><label>Dokumenty<input name="documents"></label><label>Kluczyki<input name="keys"></label><label>Koło / zestaw<input name="spare"></label><label>Multimedia<input name="multimedia"></label><label>Wyposażenie<input name="equipment"></label><label class="span-3">Widoczne uszkodzenia<textarea name="damage" rows="3"></textarea></label><label class="span-3">Potwierdzony zakres zgłoszenia<textarea name="complaint_confirmed" rows="3"><%= order.complaint||'' %></textarea></label><label class="span-3">Uwagi<textarea name="notes" rows="2"></textarea></label></div><div class="notice warning" style="margin-top:10px">Na dokumencie zostaną dodane konfigurowalne warunki warsztatu dotyczące diagnostyki, jazdy próbnej, dodatkowych kosztów, rzeczy w pojeździe i ukrytych usterek.</div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary" type="submit">Zapisz</button></div></form></div>
<div class="modal" id="additional-modal" hidden><form class="modal-card wide" method="post" action="<%= basePath %>/orders/<%= order.id %>/protocols"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="type" value="additional_costs"><div class="modal-head"><h2>Protokół dodatkowych kosztów</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid three"><label class="span-3">Powód rozszerzenia<input name="additional_reason" placeholder="np. usterka ujawniona po demontażu"></label><label class="span-3">Dodatkowe prace / części<textarea name="additional_description" rows="4" required></textarea></label><label>Koszt netto<input name="additional_net" type="number" step="0.01" min="0" required></label><label>VAT %<select name="vat_rate"><option>23</option><option>8</option><option>5</option><option>0</option></select></label><label>Rabat %<input name="discount_percent" type="number" step="0.01" min="0" max="100" value="0"></label><label class="span-3">Uwagi<textarea name="notes" rows="2"></textarea></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary" type="submit">Zapisz protokół</button></div></form></div>
<div class="modal" id="release-modal" hidden><form class="modal-card wide" method="post" action="<%= basePath %>/orders/<%= order.id %>/protocols"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="type" value="release"><div class="modal-head"><h2>Protokół wydania</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid three"><label>Wydano osobie<input name="released_to"></label><label>Status płatności<select name="payment_status"><option>Zapłacono</option><option>Do zapłaty</option><option>Przelew terminowy</option></select></label><label>Kluczyki wydane<input name="keys"></label><label class="span-3">Podsumowanie wykonanych prac<textarea name="work_summary" rows="4"><% items.forEach(i=>{ %><%= i.description %>
<% }) %></textarea></label><label class="span-3">Zalecenia<textarea name="recommendations" rows="3"></textarea></label><label class="span-3">Uwagi<textarea name="notes" rows="2"></textarea></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary" type="submit">Zapisz</button></div></form></div>
<%- include('../partials/footer') %>
