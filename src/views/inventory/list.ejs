<%- include('../partials/header') %>
<div class="toolbar"><button class="button primary" data-open-modal="product-modal">＋ Nowy towar</button><a class="button" href="<%= basePath %>/catalog">Katalog Auto Partner</a><form class="toolbar-right searchbox" method="get"><span>⌕</span><input name="q" value="<%= q %>" placeholder="Nazwa, kod, EAN"></form></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Nazwa</th><th>Kod</th><th>Producent</th><th>Jedn.</th><th class="right">Dostępne / stan</th><th class="right">Zakup netto</th><th class="right">Sprzedaż netto</th><th class="right">Sprzedaż brutto</th><th>Lokalizacja</th><th></th></tr></thead><tbody><% products.forEach(p=>{ %><tr class="<%= p.stock_qty<=p.min_stock?'low-stock-row':'' %>"><td class="description"><strong><%= p.name %></strong><small><%= p.supplier_name||'' %></small></td><td><%= p.supplier_sku||p.manufacturer_sku||'—' %></td><td><%= p.manufacturer||'—' %></td><td><%= p.unit %></td><td class="right"><strong><%= p.stock_qty-p.reserved_qty %> / <%= p.stock_qty %></strong></td><td class="right"><%= pln(p.purchase_price_net) %></td><td class="right"><%= pln(p.sale_price_net) %></td><td class="right"><%= pln(p.sale_price_net*(1+p.vat_rate/100)) %></td><td><%= p.location||'—' %></td><td><button class="button small" data-open-adjust="adjust-<%= p.id %>">Korekta</button><div class="inline-transfer" id="adjust-<%= p.id %>" hidden><form method="post" action="<%= basePath %>/inventory/products/<%= p.id %>/adjust"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="quantity_delta" type="number" step="0.01" placeholder="np. 2 lub -1" required><input name="notes" placeholder="Powód"><button class="button small primary">Zapisz</button></form></div></td></tr><% }) %></tbody></table></div><% if(!products.length){ %><div class="empty">Magazyn jest pusty.</div><% } %></section>
<div class="modal" id="product-modal" hidden><form class="modal-card wide" method="post" action="<%= basePath %>/inventory/products"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Nowy towar</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid three"><label class="span-2">Nazwa<input name="name" required></label><label>Dostawca<select name="supplier_id"><option value="">Brak</option><% suppliers.forEach(s=>{ %><option value="<%= s.id %>"><%= s.name %></option><% }) %></select></label><label>Kod dostawcy<input name="supplier_sku"></label><label>Producent<input name="manufacturer"></label><label>Numer producenta<input name="manufacturer_sku"></label><label>Kod EAN<input name="barcode"></label><label>Jednostka<select name="unit"><option>szt.</option><option>kpl.</option><option>l</option><option>kg</option></select></label><label>VAT<select name="vat_rate"><option>23</option><option>8</option><option>5</option><option>0</option></select></label><label>Cena zakupu netto<input name="purchase_price_net" type="number" step="0.01" min="0"></label><label>Cena sprzedaży netto<input name="sale_price_net" type="number" step="0.01" min="0"></label><label>Stan początkowy<input name="stock_qty" type="number" step="0.01" value="0"></label><label>Stan minimalny<input name="min_stock" type="number" step="0.01" value="0"></label><label>Lokalizacja<input name="location"></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary">Dodaj towar</button></div></form></div>
<%- include('../partials/footer') %>
