<%- include('partials/header') %><div class="page-head"><div><h1>Dziennik zmian</h1><p class="muted">Ostatnie operacje użytkowników i akceptacje klientów.</p></div></div><section class="card table-wrap"><table><thead><tr><th>Data</th><th>Użytkownik</th><th>Akcja</th><th>Obiekt</th><th>Szczegóły</th></tr></thead><tbody><% logs.forEach(l => { %><tr><td><%= new Date(l.created_at).toLocaleString('pl-PL') %></td><td><%= l.user_email || 'Klient / system' %></td><td><%= l.action %></td><td><%= l.entity_type %> #<%= l.entity_id || '—' %></td><td class="small"><%= l.details || '—' %></td></tr><% }) %></tbody></table></section><%- include('partials/footer') %>
