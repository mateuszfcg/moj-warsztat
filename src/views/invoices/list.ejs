<%- include('../partials/header') %>
<div class="toolbar"><a class="button primary" href="<%= basePath %>/orders">＋ Wystaw ze zlecenia</a><button class="button danger disabled" disabled>Usuń zaznaczone</button><div class="toolbar-right"><label class="searchbox"><span>⌕</span><input placeholder="Szukaj" oninput="const q=this.value.toLowerCase();document.querySelectorAll('tbody tr').forEach(r=>r.hidden=!r.innerText.toLowerCase().includes(q))"></label></div></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Numer dokumentu</th><th>E-faktura</th><th>Klient</th><th>Data wystawienia</th><th>Data sprzedaży</th><th>Termin</th><th>Status</th></tr></thead><tbody><% invoices.forEach(i=>{ %><tr><td><a class="number-link" href="<%= basePath %>/invoices/<%= i.id %>">▧ <%= i.number %></a></td><td><span class="status-badge status-<%= i.ksef_status %>"><%= i.ksef_status %></span></td><td class="client-cell"><%= i.client_name %></td><td><%= formatDate(i.issue_date) %></td><td><%= formatDate(i.sale_date) %></td><td><%= formatDate(i.due_date) %></td><td><span class="status-badge status-<%= i.status %>"><%= i.status %></span></td></tr><% }) %></tbody></table></div><% if(!invoices.length){ %><div class="empty">Brak faktur. Fakturę utworzysz bezpośrednio ze zlecenia.</div><% } %><div class="table-footer"><span><%= invoices.length %> dokumentów</span></div></section>
<%- include('../partials/footer') %>
