<%- include('../partials/header') %>
<div class="page-head"><div><div class="eyebrow">Sprzedaż</div><h1>Faktury i korekty</h1><p class="muted">Fakturę możesz wystawić także bez zlecenia.</p></div><div class="actions"><a class="button" href="<%= basePath %>/invoices/new?type=invoice_receipt">FV do paragonu</a><a class="button primary" href="<%= basePath %>/invoices/new">＋ Nowa faktura</a></div></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Numer</th><th>Typ</th><th>Klient</th><th>Data</th><th>Status</th><th>KSeF</th><th></th></tr></thead><tbody><% invoices.forEach(i=>{ %><tr><td><a class="number-link" href="<%= basePath %>/invoices/<%= i.id %>"><%= i.number %></a><% if(i.corrected_number){ %><small>do <%= i.corrected_number %></small><% } %></td><td><%= i.document_type==='correction'?'Korekta':i.document_type==='invoice_receipt'?'FV do paragonu':'Faktura' %></td><td><%= i.client_name %></td><td><%= formatDate(i.issue_date) %></td><td><span class="badge status-<%= i.status %>"><%= label('invoice',i.status) %></span></td><td><span class="badge"><%= label('ksef',i.ksef_status) %></span></td><td class="right"><a class="button small" href="<%= basePath %>/invoices/<%= i.id %>/edit">Edytuj</a> <a class="button small" target="_blank" href="<%= basePath %>/invoices/<%= i.id %>/pdf">Drukuj</a></td></tr><% }) %></tbody></table></div><% if(!invoices.length){ %><div class="empty">Brak dokumentów sprzedaży.</div><% } %><div class="table-footer"><span><%= invoices.length %> dokumentów</span></div></section>
<%- include('../partials/footer') %>
