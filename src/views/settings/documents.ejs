<%- include('../partials/header') %>
<div class="page-title"><div><h1>Wygląd faktur i dokumentów</h1><p>Wspólna identyfikacja faktur, protokołów przyjęcia i protokołów wydania.</p></div><a class="button" href="<%= basePath %>/settings">Wróć</a></div>
<div class="settings-layout">
  <div>
    <form class="card" method="post" action="<%= basePath %>/settings/documents"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <h2>Kolory i układ</h2><div class="form-grid"><label>Kolor przewodni<div class="color-row"><input name="document_accent_color" value="<%= formSettings.document_accent_color %>"><input type="color" value="<%= formSettings.document_accent_color %>" data-color-input="--doc-accent"></div></label><label>Nagłówek tabeli<div class="color-row"><input name="document_table_header_color" value="<%= formSettings.document_table_header_color %>"><input type="color" value="<%= formSettings.document_table_header_color %>" data-color-input="--doc-head"></div></label><label>Kolor tekstu tabeli<input name="document_table_text_color" type="color" value="<%= formSettings.document_table_text_color %>"></label><label>Rozmiar czcionki<input name="document_font_size" type="number" min="7" max="12" value="<%= formSettings.document_font_size %>"></label><label class="checkbox-row"><input type="checkbox" name="document_compact" value="1" <%= formSettings.document_compact?'checked':'' %>><span>Kompaktowe odstępy w tabelach</span></label><label class="checkbox-row"><input type="checkbox" name="document_show_logo" value="1" <%= formSettings.document_show_logo?'checked':'' %>><span>Pokazuj logo</span></label><label class="checkbox-row"><input type="checkbox" name="document_show_company_contact" value="1" <%= formSettings.document_show_company_contact?'checked':'' %>><span>Pokazuj dane kontaktowe</span></label></div>
      <hr><h2>Kolumny faktury</h2><div class="form-grid"><% [['invoice_show_lp','Lp.'],['invoice_show_unit','Jednostka'],['invoice_show_vat_rate','Stawka VAT'],['invoice_show_vat_value','Kwota VAT']].forEach(([name,label])=>{ %><label class="checkbox-row"><input type="checkbox" name="<%= name %>" value="1" <%= formSettings[name]?'checked':'' %>><span><%= label %></span></label><% }) %><label class="checkbox-row locked"><input type="checkbox" checked disabled><span>Wartość netto (wymagana)</span></label><label class="checkbox-row locked"><input type="checkbox" checked disabled><span>Wartość brutto (wymagana)</span></label></div>
      <hr><h2>Płatność i stopki</h2><div class="form-grid"><label class="checkbox-row span-2"><input type="checkbox" name="document_show_bank_account" value="1" <%= formSettings.document_show_bank_account?'checked':'' %>><span>Pokazuj rachunek bankowy na fakturze</span></label><label>Rachunek bankowy<input name="document_bank_account" value="<%= formSettings.document_bank_account %>"></label><label>Nazwa banku<input name="document_bank_name" value="<%= formSettings.document_bank_name %>"></label><label class="span-2">Stopka faktury<textarea name="invoice_footer" rows="3"><%= formSettings.invoice_footer %></textarea></label><label class="span-2">Stopka protokołów<textarea name="protocol_footer" rows="3"><%= formSettings.protocol_footer %></textarea></label><label class="checkbox-row"><input type="checkbox" name="protocol_show_order_items" value="1" <%= formSettings.protocol_show_order_items?'checked':'' %>><span>Pozycje zlecenia na protokołach</span></label><label class="checkbox-row locked"><input type="checkbox" checked disabled><span>Netto, VAT i brutto na protokołach (wymagane)</span></label></div>
      <div class="form-actions"><button class="button primary" type="submit">Zapisz wygląd dokumentów</button></div>
    </form>
    <form class="card" method="post" enctype="multipart/form-data" action="<%= basePath %>/settings/documents/logo"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h2>Logo</h2><label>Plik JPG lub PNG<input type="file" name="logo" accept="image/jpeg,image/png" required></label><% if(formSettings.document_logo_path){ %><p class="small muted">Aktualny plik: <%= formSettings.document_logo_path %></p><% } %><div class="form-actions"><button class="button" type="submit">Wgraj logo</button></div></form>
  </div>
  <div class="preview-document" style="--doc-accent:<%= formSettings.document_accent_color %>;--doc-head:<%= formSettings.document_table_header_color %>"><div class="preview-doc-head"><div class="preview-logo">LOGO</div><div class="preview-title"><strong>FAKTURA VAT</strong><span>FV/2026/0001</span></div></div><div class="preview-parties"><div class="preview-box"><strong>Sprzedawca</strong><br><%= company.name %><br><%= company.address %><br>NIP: <%= company.nip||'—' %></div><div class="preview-box"><strong>Nabywca</strong><br>Przykładowy klient<br>ul. Klienta 1<br>NIP: 1234567890</div></div><table class="preview-table"><thead><tr><% if(formSettings.invoice_show_lp){ %><th>Lp.</th><% } %><th>Nazwa</th><th>Ilość</th><% if(formSettings.invoice_show_unit){ %><th>J.m.</th><% } %><th>Netto</th><% if(formSettings.invoice_show_vat_rate){ %><th>VAT</th><% } %><% if(formSettings.invoice_show_vat_value){ %><th>Kwota VAT</th><% } %><th>Brutto</th></tr></thead><tbody><tr><% if(formSettings.invoice_show_lp){ %><td>1</td><% } %><td>Usługa serwisowa</td><td>1,50</td><% if(formSettings.invoice_show_unit){ %><td>rbh</td><% } %><td>300,00</td><% if(formSettings.invoice_show_vat_rate){ %><td>23%</td><% } %><% if(formSettings.invoice_show_vat_value){ %><td>69,00</td><% } %><td>369,00</td></tr></tbody></table><div class="preview-total">Do zapłaty: 369,00 zł</div><p class="small muted" style="margin-top:26px"><%= formSettings.invoice_footer %></p></div>
</div>
<%- include('../partials/footer') %>
