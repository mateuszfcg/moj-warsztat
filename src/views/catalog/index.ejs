<%- include('../partials/header') %>
<div class="catalog-head"><div><span class="eyebrow">Dostawcy</span><h1>Katalog części</h1><p>Pozycje z katalogu sprzedażowego i dokumentów WZ możesz jednym działaniem przekazać do magazynu albo do wybranego zlecenia.</p></div><% if(supplier?.catalog_url){ %><a class="button primary" href="<%= supplier.catalog_url %>" target="_blank" rel="noreferrer">Otwórz AP CAT ↗</a><% } %></div>
<div class="notice warning"><strong>Auto Partner:</strong> katalog poniżej działa obecnie jako warstwa integracyjna i dane demonstracyjne. Do prawdziwej synchronizacji cen, stanów, koszyków i WZ potrzebny jest oficjalny dostęp lub dokumentacja od opiekuna Auto Partner. Dane logowania nie są pobierane przez aplikację.</div>
<div class="toolbar"><div class="segmented"><a class="<%= tab==='sales'?'active':'' %>" href="<%= basePath %>/catalog?tab=sales">Sprzedaż</a><a class="<%= tab==='wz'?'active':'' %>" href="<%= basePath %>/catalog?tab=wz">WZ</a></div><form class="toolbar-right searchbox" method="get"><input type="hidden" name="tab" value="<%= tab %>"><span>⌕</span><input name="q" value="<%= q %>" placeholder="Kod, producent, nazwa"></form></div>
<% const rows=tab==='sales'?catalogItems:wzItems; %>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Kod</th><th>Producent</th><th>Nazwa</th><% if(tab==='wz'){ %><th>Dokument</th><% } %><th>Dostępność</th><th class="right">Zakup netto</th><th class="right">Sprzedaż netto</th><th class="right">Sprzedaż brutto</th><th>Akcje</th></tr></thead><tbody><% rows.forEach(i=>{ const sale=tab==='sales'?i.suggested_sale_price_net:i.purchase_price_net; %><tr><td><strong><%= i.supplier_sku||i.manufacturer_sku||'—' %></strong><small><%= i.manufacturer_sku||'' %></small></td><td><%= i.manufacturer||'—' %></td><td class="description"><%= i.name %></td><% if(tab==='wz'){ %><td><%= i.document_number %><small><%= formatDate(i.issue_date) %></small></td><% } %><td><%= tab==='sales'?(i.stock_text||'—'):(i.added_to_stock?'W magazynie':'Z WZ') %></td><td class="right"><%= pln(i.purchase_price_net) %></td><td class="right"><%= pln(sale) %></td><td class="right"><strong><%= pln(sale*(1+i.vat_rate/100)) %></strong></td><td><div class="catalog-actions"><form method="post" action="<%= basePath %>/<%= tab==='sales'?'catalog/items/'+i.id:'purchase-items/'+i.id %>/add-stock"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="quantity" type="number" min="0.01" step="0.01" value="<%= tab==='sales'?1:i.quantity %>"><button class="button small success" <%= tab==='wz'&&i.added_to_stock?'disabled':'' %>>＋ Magazyn</button></form><form method="post" action="<%= basePath %>/<%= tab==='sales'?'catalog/items/'+i.id:'purchase-items/'+i.id %>/add-order"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="quantity" type="number" min="0.01" step="0.01" value="<%= tab==='sales'?1:i.quantity %>"><select name="work_order_id" required><option value="">Aktualne zlecenie…</option><% orders.forEach(o=>{ %><option value="<%= o.id %>"><%= o.number %> · <%= o.registration||'bez pojazdu' %> · <%= o.client_name||'bez klienta' %></option><% }) %></select><button class="button small primary">＋ Zlecenie</button></form></div></td></tr><% }) %></tbody></table></div><% if(!rows.length){ %><div class="empty">Brak pozycji. Wprowadź dokument WZ albo podłącz źródło katalogowe.</div><% } %></section>
<%- include('../partials/footer') %>
