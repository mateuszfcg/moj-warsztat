<%- include('../partials/header') %>
<div class="toolbar"><button class="button primary" type="button" data-open-modal="client-modal">＋ Dodaj klienta</button><div class="toolbar-right"><form method="get" class="toolbar"><label class="searchbox"><span>⌕</span><input name="q" value="<%= q %>" placeholder="Nazwa, NIP, telefon lub e-mail"></label><button class="button icon" type="submit">↵</button></form></div></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Nazwa</th><th>Typ</th><th>Telefon</th><th>E-mail</th><th>NIP</th><th>Pojazdy</th><th></th></tr></thead><tbody>
<% clients.forEach(client=>{ %><tr><td><a class="number-link" href="<%= basePath %>/clients/<%= client.id %>"><%= client.name %></a></td><td><%= client.type==='company'?'Firma':'Osoba' %></td><td><%= client.phone||'—' %></td><td><%= client.email||'—' %></td><td><%= client.nip||'—' %></td><td><%= client.vehicle_count %></td><td class="right"><a href="<%= basePath %>/clients/<%= client.id %>/edit">Edytuj</a></td></tr><% }) %>
</tbody></table></div><% if(!clients.length){ %><div class="empty">Nie znaleziono klientów.</div><% } %><div class="table-footer"><span><%= clients.length %> klientów</span></div></section>
<div class="modal" id="client-modal" hidden><form class="modal-card" method="post" action="<%= basePath %>/clients"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="return_to" value="/clients"><div class="modal-head"><h2>Nowy klient</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid"><label>Typ<select name="type"><option value="person">Osoba</option><option value="company">Firma</option></select></label><label>Nazwa / imię i nazwisko<input name="name" required></label><label>NIP<input name="nip"></label><label>Telefon<input name="phone"></label><label>E-mail<input name="email" type="email"></label><label>Adres<input name="address"></label><label class="span-2">Notatki<textarea name="notes" rows="3"></textarea></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary" type="submit">Zapisz klienta</button></div></form></div>
<%- include('../partials/footer') %>
