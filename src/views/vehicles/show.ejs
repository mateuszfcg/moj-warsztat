<%- include('../partials/header') %>
<div class="page-head"><div><h1><%= vehicle.make || 'Pojazd' %> <%= vehicle.model || '' %></h1><p class="muted"><%= vehicle.registration || 'Brak numeru rejestracyjnego' %></p></div><div class="actions"><a class="button primary" href="<%= basePath %>/orders/new?vehicle_id=<%= vehicle.id %>">+ Zlecenie</a><a class="button" href="<%= basePath %>/vehicles/<%= vehicle.id %>/edit">Edytuj</a></div></div>
<div class="two-col"><section class="card details"><h2>Dane pojazdu</h2><dl><dt>Właściciel</dt><dd><a href="<%= basePath %>/clients/<%= vehicle.client_id %>"><%= vehicle.client_name %></a></dd><dt>VIN</dt><dd class="mono"><%= vehicle.vin || '—' %></dd><dt>Rejestracja</dt><dd><%= vehicle.registration || '—' %></dd><dt>Rok</dt><dd><%= vehicle.year || '—' %></dd><dt>Silnik</dt><dd><%= vehicle.engine || '—' %></dd><dt>Paliwo</dt><dd><%= vehicle.fuel || '—' %></dd><dt>Przebieg</dt><dd><%= vehicle.mileage ? vehicle.mileage + ' km' : '—' %></dd><dt>Kolor</dt><dd><%= vehicle.color || '—' %></dd></dl></section><section class="card"><h2>Notatki</h2><p class="pre"><%= vehicle.notes || 'Brak notatek.' %></p></section></div>
<section class="card"><div class="card-head"><h2>Historia serwisowa</h2><a href="<%= basePath %>/orders/new?vehicle_id=<%= vehicle.id %>">Nowe zlecenie</a></div><div class="table-wrap"><table><thead><tr><th>Numer</th><th>Status</th><th>Zgłoszenie</th><th>Data</th></tr></thead><tbody><% orders.forEach(o => { %><tr><td><a href="<%= basePath %>/orders/<%= o.id %>"><%= o.number %></a></td><td><span class="badge status-<%= o.status %>"><%= o.status %></span></td><td><%= o.complaint || '—' %></td><td><%= formatDate(o.created_at) %></td></tr><% }) %></tbody></table></div><% if (!orders.length) { %><p class="empty">Brak zleceń.</p><% } %></section>
<%- include('../partials/footer') %>
