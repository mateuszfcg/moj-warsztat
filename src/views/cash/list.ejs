<%- include('../partials/header') %>
<div class="metric-grid"><div class="metric-card positive"><span>Wpływy</span><strong><%= pln(totals.income) %></strong></div><div class="metric-card negative"><span>Wydatki</span><strong><%= pln(totals.expense) %></strong></div><div class="metric-card"><span>Saldo</span><strong><%= pln(totals.income-totals.expense) %></strong></div></div>
<div class="toolbar"><button class="button primary" data-open-modal="cash-modal">＋ Operacja kasowa</button></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Data</th><th>Typ</th><th>Kategoria</th><th>Opis / dokument</th><th>Metoda</th><th class="right">Kwota brutto</th></tr></thead><tbody><% transactions.forEach(t=>{ %><tr><td><%= formatDate(t.occurred_on) %></td><td><span class="status <%= t.type==='income'?'status-done':'status-cancelled' %>"><%= t.type==='income'?'Wpływ':'Wydatek' %></span></td><td><%= t.category %></td><td><%= t.description||t.invoice_number||t.purchase_number||'—' %></td><td><%= label('payment',t.payment_method) %></td><td class="right"><strong><%= t.type==='income'?'+':'−' %><%= pln(t.amount_gross) %></strong></td></tr><% }) %></tbody></table></div><% if(!transactions.length){ %><div class="empty">Brak operacji kasowych.</div><% } %></section>
<div class="modal" id="cash-modal" hidden><form class="modal-card" method="post" action="<%= basePath %>/cash"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Operacja kasowa</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid"><label>Typ<select name="type"><option value="income">Wpływ</option><option value="expense">Wydatek</option></select></label><label>Data<input name="occurred_on" type="date" value="<%= new Date().toISOString().slice(0,10) %>"></label><label>Kategoria<input name="category" value="inne"></label><label>Metoda<select name="payment_method"><option value="cash">Gotówka</option><option value="transfer">Przelew</option><option value="card">Karta</option></select></label><label>Kwota brutto<input name="amount_gross" type="number" step="0.01" min="0.01" required></label><label class="span-2">Opis<textarea name="description" rows="3"></textarea></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary">Zapisz</button></div></form></div>
<%- include('../partials/footer') %>
