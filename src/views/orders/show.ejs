<%- include('../partials/header') %>
<% const statusLabels={draft:'Nowe zlecenie',estimate:'Wycena',approved:'Zaakceptowane',in_progress:'W trakcie naprawy',ready:'Gotowy do odbioru',completed:'Zakończone',cancelled:'Anulowane'}; %>
<div class="order-head">
  <div><h1><%= order.number %></h1><div class="muted"><%= order.client_name||'Bez klienta' %> · <%= order.vehicle_id?(order.registration||'bez rejestracji'):'Bez pojazdu' %> · <%= order.make||'' %> <%= order.model||'' %></div></div>
  <span class="status-badge status-<%= order.status %>"><%= statusLabels[order.status]||order.status %></span>
  <div class="spacer"></div>
  <div class="price-toggle"><a class="<%= priceMode==='net'?'active':'' %>" href="?price=net">NETTO</a><a class="<%= priceMode==='gross'?'active':'' %>" href="?price=gross">BRUTTO</a></div>
  <a class="button" href="<%= basePath %>/orders/<%= order.id %>/edit">Edytuj</a>
  <% if(!invoice){ %><form method="post" action="<%= basePath %>/orders/<%= order.id %>/invoice"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button primary" type="submit" <%= !order.client_id?'disabled title=\"Najpierw przypisz klienta do zlecenia\"':'' %>>Wystaw fakturę</button></form><% }else{ %><a class="button primary" href="<%= basePath %>/invoices/<%= invoice.id %>"><%= invoice.number %></a><% } %>
</div>
<div class="summary-strip"><span>Przebieg: <strong><%= order.mileage_in?order.mileage_in+' km':'—' %></strong></span><span>Paliwo: <strong><%= order.fuel_level||'—' %></strong></span><span>Przyjęcie: <strong><%= order.scheduled_for?formatDate(order.scheduled_for):'—' %></strong></span><span>Akceptacja: <strong><%= order.accepted_at?formatDate(order.accepted_at):'nie' %></strong></span><span class="spacer"></span><span>Wartość: <strong><%= pln(priceMode==='gross'?totals.gross:totals.net) %></strong></span></div>
<div class="detail-grid">
  <section class="card"><div class="card-head"><h2>Zlecenie i pojazd</h2></div><dl class="compact-dl"><dt>Zgłoszenie</dt><dd class="pre"><%= order.complaint||'—' %></dd><dt>Diagnoza</dt><dd class="pre"><%= order.diagnosis||'—' %></dd><dt>Notatki</dt><dd class="pre"><%= order.notes||'—' %></dd><dt>VIN</dt><dd class="mono"><%= order.vin||'—' %></dd><dt>Silnik</dt><dd><%= order.engine||'—' %></dd></dl></section>
  <section class="card"><div class="card-head"><h2>Akceptacja kosztorysu</h2></div><p class="muted small">Link dla klienta pokazuje wyłącznie ceny brutto.</p><div style="display:flex;gap:7px"><input readonly value="<%= acceptanceUrl %>" id="acceptance-url"><button class="button" type="button" data-copy="#acceptance-url">Kopiuj</button></div><a class="button small" style="margin-top:10px" target="_blank" href="<%= basePath %>/accept/<%= order.acceptance_token %>">Podgląd klienta ↗</a></section>
</div>
<section class="data-panel order-items" style="margin-bottom:14px">
  <div class="toolbar" style="padding:9px;margin:0;border-bottom:1px solid var(--line)"><button class="button primary" type="button" data-open-modal="item-modal">＋ Dodaj pozycję</button><div class="toolbar-right"><span>Netto: <strong><%= pln(totals.net) %></strong></span><span>VAT: <strong><%= pln(totals.vat) %></strong></span><span>Brutto: <strong><%= pln(totals.gross) %></strong></span></div></div>
  <div class="table-wrap"><table class="data-table"><thead><tr><th>Typ</th><th>Opis</th><th>Ilość</th><th class="right">Cena jedn. <%= priceMode==='gross'?'brutto':'netto' %></th><th class="right">Wartość <%= priceMode==='gross'?'brutto':'netto' %></th><th>VAT</th><th class="right">Koszt własny</th><th class="right">Marża netto</th><th></th></tr></thead><tbody>
  <% items.forEach(item=>{ const t=lineTotals(item); const unitGross=Number(item.unit_price_net)*(1+Number(item.vat_rate)/100); const margin=t.net-(Number(item.cost_net)*Number(item.quantity)); %><tr><td><%= item.type==='labor'?'Roboczogodzina':item.type==='part'?'Część':item.type==='material'?'Materiał':'Usługa' %></td><td class="description"><%= item.description %></td><td><strong><%= item.quantity %></strong> <%= item.unit %></td><td class="right"><%= pln(priceMode==='gross'?unitGross:item.unit_price_net) %></td><td class="right"><strong><%= pln(priceMode==='gross'?t.gross:t.net) %></strong></td><td><%= item.vat_rate %>%</td><td class="right money-muted"><%= pln(Number(item.cost_net)*Number(item.quantity)) %></td><td class="right money-positive"><%= pln(margin) %></td><td><form method="post" action="<%= basePath %>/orders/<%= order.id %>/items/<%= item.id %>/delete" onsubmit="return confirm('Usunąć pozycję?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="delete-button" type="submit">×</button></form></td></tr><% }) %>
  </tbody></table></div><% if(!items.length){ %><div class="empty">Brak pozycji. Dodaj roboczogodziny, części lub materiały.</div><% } %>
</section>
<div class="two-col">
  <section class="card"><div class="card-head"><h2>Protokoły</h2><div><% if(settings.intake_protocol_enabled){ %><button class="button small" type="button" data-open-modal="intake-modal">Protokół przyjęcia</button><% } %> <% if(settings.release_protocol_enabled){ %><button class="button small" type="button" data-open-modal="release-modal">Protokół wydania</button><% } %></div></div>
    <% if(protocols.length){ %><div class="table-wrap"><table class="data-table" style="min-width:520px"><thead><tr><th>Dokument</th><th>Data</th><th>Podpisujący</th><th></th></tr></thead><tbody><% protocols.forEach(p=>{ %><tr><td><%= p.type==='release'?'Protokół wydania':'Protokół przyjęcia' %></td><td><%= formatDate(p.created_at) %></td><td><%= p.signed_by||'—' %></td><td class="right"><a class="button small" target="_blank" href="<%= basePath %>/protocols/<%= p.id %>/pdf">Otwórz PDF</a> <a class="button small" href="<%= basePath %>/protocols/<%= p.id %>/pdf?download=1">Pobierz</a></td></tr><% }) %></tbody></table></div><% }else{ %><p class="muted small">Nie utworzono jeszcze protokołów.</p><% } %>
  </section>
  <section class="card"><div class="card-head"><h2>Zdjęcia i dokumenty</h2></div><form method="post" action="<%= basePath %>/orders/<%= order.id %>/attachments" enctype="multipart/form-data" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="file" name="files" multiple accept="image/jpeg,image/png,image/webp,application/pdf"><button class="button" type="submit">Dodaj pliki</button></form><div class="attachment-grid" style="margin-top:10px"><% attachments.forEach(a=>{ %><a href="<%= basePath %>/uploads/<%= a.filename %>" target="_blank" class="attachment"><% if(a.mime_type.startsWith('image/')){ %><img src="<%= basePath %>/uploads/<%= a.filename %>" alt=""><% }else{ %><div class="file-icon">PDF</div><% } %><span><%= a.original_name %></span></a><% }) %></div></section>
</div>

<div class="modal" id="item-modal" hidden><form class="modal-card" method="post" action="<%= basePath %>/orders/<%= order.id %>/items"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Dodaj pozycję zlecenia</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid"><label>Rodzaj<select name="type" id="item-type"><option value="labor">Roboczogodzina</option><option value="part">Część</option><option value="material">Materiał</option><option value="service">Usługa zewnętrzna</option></select></label><label>Wprowadzane ceny<select name="input_price_mode"><option value="net" <%= priceMode==='net'?'selected':'' %>>Netto</option><option value="gross" <%= priceMode==='gross'?'selected':'' %>>Brutto</option></select></label><label class="span-2">Nazwa / opis<input name="description" required placeholder="np. Wymiana klocków hamulcowych"></label><div data-labor-fields class="span-2 form-grid"><label>Liczba roboczogodzin<input name="hours" type="number" step="0.05" min="0.05" value="1"></label><label>Jednostka<input value="RBH" disabled></label></div><div data-regular-fields class="span-2 form-grid" hidden><label>Ilość<input name="quantity" type="number" step="0.01" min="0.01" value="1"></label><label>Jednostka<select name="unit"><option>szt.</option><option>kpl.</option><option>l</option><option>kg</option><option>usł.</option></select></label></div><label>Cena sprzedaży za jednostkę<input id="item-price" data-labor-rate="<%= settings.labor_sale_rate_net %>" name="price_input" type="number" step="0.01" min="0" value="<%= settings.labor_sale_rate_net %>"></label><label>Koszt własny netto / jednostkę<input id="item-cost" data-labor-cost="<%= settings.labor_cost_rate_net %>" name="cost_net" type="number" step="0.01" min="0" value="<%= settings.labor_cost_rate_net %>"></label><label>Stawka VAT<select name="vat_rate"><option value="23" <%= settings.labor_vat_rate===23?'selected':'' %>>23%</option><option value="8">8%</option><option value="5">5%</option><option value="0">0%</option></select></label></div><div class="notice" style="margin-top:10px">Dla roboczogodziny cena i koszt są automatycznie pobierane z ustawień warsztatu. Możesz je zmienić dla konkretnej pozycji.</div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary" type="submit">Dodaj pozycję</button></div></form></div>

<div class="modal" id="intake-modal" hidden><form class="modal-card wide" method="post" action="<%= basePath %>/orders/<%= order.id %>/protocols"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="type" value="intake"><div class="modal-head"><h2>Protokół przyjęcia pojazdu</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid three"><label>Dokumenty<input name="documents" placeholder="np. dowód rejestracyjny"></label><label>Kluczyki<input name="keys" placeholder="np. 2 szt."></label><label>Koło / zestaw naprawczy<input name="spare"></label><label>Multimedia<input name="multimedia"></label><label>Wyposażenie pozostawione<input name="equipment"></label><label>Stan pojazdu<input name="vehicle_condition" placeholder="np. zabrudzony, sprawny"></label><label class="span-3">Widoczne uszkodzenia<textarea name="damage" rows="3"></textarea></label><label class="span-3">Potwierdzony zakres zgłoszenia<textarea name="complaint_confirmed" rows="3"><%= order.complaint||'' %></textarea></label><label class="span-3">Uwagi<textarea name="notes" rows="2"></textarea></label><label class="span-3">Podpisujący<input name="signed_by" placeholder="Imię i nazwisko klienta"></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary" type="submit">Zapisz protokół przyjęcia</button></div></form></div>

<div class="modal" id="release-modal" hidden><form class="modal-card wide" method="post" action="<%= basePath %>/orders/<%= order.id %>/protocols"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="type" value="release"><div class="modal-head"><h2>Protokół wydania pojazdu</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid three"><label>Wydano osobie<input name="released_to" placeholder="Imię i nazwisko"></label><label>Status płatności<select name="payment_status"><option>Zapłacono</option><option>Do zapłaty</option><option>Przelew terminowy</option></select></label><label>Kluczyki wydane<input name="keys" placeholder="np. 2 szt."></label><label class="span-3">Podsumowanie wykonanych prac<textarea name="work_summary" rows="4"><% items.forEach(i=>{ %><%= i.description %>
<% }) %></textarea></label><label class="span-3">Zalecenia po naprawie<textarea name="recommendations" rows="3"></textarea></label><label class="span-3">Uwagi<textarea name="notes" rows="2"></textarea></label><label class="span-3">Podpisujący<input name="signed_by" placeholder="Imię i nazwisko odbierającego"></label></div><div class="notice" style="margin-top:10px">Na protokole wydania pozycje i podsumowanie zostaną pokazane w kwotach netto i brutto.</div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary" type="submit">Zapisz protokół wydania</button></div></form></div>
<%- include('../partials/footer') %>
