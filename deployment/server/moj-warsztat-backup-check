#!/usr/bin/env bash
set -Eeuo pipefail
CONFIG=${MOJ_WARSZTAT_BACKUP_CONFIG:-/etc/moj-warsztat/backup.env}
[[ -f "$CONFIG" ]] || { echo "Brak konfiguracji: $CONFIG" >&2; exit 1; }
# shellcheck disable=SC1090
source "$CONFIG"
if [[ -z "${RESTIC_REPOSITORY:-}" ]]; then
  echo "Backup zdalny restic nie jest skonfigurowany — pomijam kontrolę."
  exit 0
fi
export RESTIC_REPOSITORY RESTIC_PASSWORD_FILE AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY
restic prune
restic check
