<!doctype html><html lang="pl"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Raport <%= from %> - <%= to %> · Mój Warsztat</title><style>body{font-family:Arial,sans-serif;color:#1f2937;margin:28px}h1{margin-bottom:4px}.muted{color:#6b7280}.actions{margin:16px 0}.actions button{padding:8px 14px}.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:20px 0}.metric{border:1px solid #d1d5db;padding:12px;border-radius:6px}.metric span{display:block;color:#6b7280;font-size:12px}.metric strong{font-size:18px}table{width:100%;border-collapse:collapse;margin-top:12px;font-size:12px}th,td{border-bottom:1px solid #e5e7eb;padding:7px;text-align:left}th{background:#f3f4f6}.right{text-align:right}@media print{.actions{display:none}body{margin:12mm}}</style></head><body><h1>Raport warsztatowy</h1><div class="muted">Zakres: <%= from %> - <%= to %></div><div class="actions"><button onclick="window.print()">Drukuj / zapisz jako PDF</button></div><div class="metrics"><div class="metric"><span>Sprzedaż netto</span><strong><%= pln(revenue.net) %></strong></div><div class="metric"><span>Sprzedaż brutto</span><strong><%= pln(revenue.gross) %></strong></div><div class="metric"><span>Marża zleceń netto</span><strong><%= pln(orderProfit.sales_net-orderProfit.cost_net) %></strong></div><div class="metric"><span>Zakupy netto</span><strong><%= pln(purchases.net) %></strong></div></div><h2>Faktury</h2><table><thead><tr><th>Numer</th><th>Data</th><th>Klient</th><th class="right">Netto</th><th class="right">VAT</th><th class="right">Brutto</th><th>Status</th></tr></thead><tbody><% invoices.forEach(i=>{ %><tr><td><%= i.number %></td><td><%= i.issue_date %></td><td><%= i.client_name||'Bez klienta' %></td><td class="right"><%= pln(i.net) %></td><td class="right"><%= pln(i.vat) %></td><td class="right"><%= pln(i.gross) %></td><td><%= label('invoice',i.status) %></td></tr><% }) %></tbody></table><h2>Statusy zleceń</h2><table><thead><tr><th>Status</th><th class="right">Liczba</th></tr></thead><tbody><% orderStatus.forEach(r=>{ %><tr><td><%= label('order',r.status) %></td><td class="right"><%= r.count %></td></tr><% }) %></tbody></table></body></html>
