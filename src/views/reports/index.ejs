<%- include('../partials/header') %>
<div class="metric-grid four"><div class="metric-card"><span>Sprzedaż netto</span><strong><%= pln(revenue.net) %></strong><small>Brutto: <%= pln(revenue.gross) %></small></div><div class="metric-card"><span>Marża zleceń netto</span><strong><%= pln(orderProfit.sales_net-orderProfit.cost_net) %></strong><small>Sprzedaż <%= pln(orderProfit.sales_net) %> · koszt <%= pln(orderProfit.cost_net) %></small></div><div class="metric-card"><span>Zakupy netto</span><strong><%= pln(purchases.net) %></strong></div><div class="metric-card"><span>Towary poniżej minimum</span><strong><%= lowStock.length %></strong></div></div>
<div class="two-col"><section class="card"><div class="card-head"><h2>Statusy zleceń</h2></div><table><thead><tr><th>Status</th><th class="right">Liczba</th></tr></thead><tbody><% orderStatus.forEach(r=>{ %><tr><td><%= orderStatuses[r.status]||r.status %></td><td class="right"><strong><%= r.count %></strong></td></tr><% }) %></tbody></table></section><section class="card"><div class="card-head"><h2>Niski stan magazynowy</h2></div><table><thead><tr><th>Towar</th><th class="right">Stan / minimum</th></tr></thead><tbody><% lowStock.forEach(p=>{ %><tr><td><%= p.name %></td><td class="right"><strong><%= p.stock_qty %> / <%= p.min_stock %></strong></td></tr><% }) %></tbody></table><% if(!lowStock.length){ %><p class="muted">Brak ostrzeżeń magazynowych.</p><% } %></section></div>
<%- include('../partials/footer') %>
