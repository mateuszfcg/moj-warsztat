<%- include('../partials/header') %>
<div class="page-head"><div><div class="eyebrow">Protokół · wersja <%= protocol.version||1 %></div><h1>Edycja protokołu <%= protocol.work_order_number %></h1><p class="muted">Zapisanie zmian cofa wcześniejszy podpis i wymaga ponownej akceptacji.</p></div><div class="actions"><a class="button" target="_blank" href="<%= basePath %>/protocols/<%= protocol.id %>/pdf">Drukuj / PDF</a><a class="button" href="<%= basePath %>/orders/<%= protocol.work_order_id %>">Anuluj</a></div></div>
<form class="card form-grid three" method="post" action="<%= basePath %>/protocols/<%= protocol.id %>/edit"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
<% if(protocol.type==='intake'){ %><label>Dokumenty<input name="documents" value="<%= body.documents||'' %>"></label><label>Kluczyki<input name="keys" value="<%= body.keys||'' %>"></label><label>Koło / zestaw<input name="spare" value="<%= body.spare||'' %>"></label><label>Multimedia<input name="multimedia" value="<%= body.multimedia||'' %>"></label><label>Wyposażenie<input name="equipment" value="<%= body.equipment||'' %>"></label><label>Stan pojazdu<select name="vehicle_condition"><option value="">—</option><% ['Bardzo dobry','Dobry','Normalne ślady użytkowania','Liczne zarysowania','Wgniecenia','Uszkodzenia lakieru','Uszkodzenia szyb','Uszkodzenia felg','Pojazd niesprawny','Dostarczony lawetą'].forEach(v=>{ %><option <%= body.vehicle_condition===v?'selected':'' %>><%= v %></option><% }) %></select></label><label class="span-3">Widoczne uszkodzenia<textarea name="damage" rows="3"><%= body.damage||'' %></textarea></label><label class="span-3">Zakres zgłoszenia<textarea name="complaint_confirmed" rows="3"><%= body.complaint_confirmed||'' %></textarea></label><% } %>
<% if(protocol.type==='release'){ %><label>Wydano osobie<input name="released_to" value="<%= body.released_to||'' %>"></label><label>Status płatności<input name="payment_status" value="<%= body.payment_status||'' %>"></label><label>Kluczyki<input name="keys" value="<%= body.keys||'' %>"></label><label class="span-3">Wykonane prace<textarea name="work_summary" rows="4"><%= body.work_summary||'' %></textarea></label><label class="span-3">Zalecenia<textarea name="recommendations" rows="3"><%= body.recommendations||'' %></textarea></label><% } %>
<% if(protocol.type==='additional_costs'){ %><label class="span-3">Powód rozszerzenia<input name="additional_reason" value="<%= body.additional_reason||'' %>"></label><label class="span-3">Dodatkowe prace / części<textarea name="additional_description" rows="4"><%= body.additional_description||'' %></textarea></label><label>Koszt netto<input name="additional_net" type="number" step="0.01" value="<%= body.additional_net||0 %>"></label><label>VAT %<input name="vat_rate" type="number" step="1" value="<%= body.vat_rate||23 %>"></label><label>Rabat %<input name="discount_percent" type="number" step="0.01" min="0" max="100" value="<%= body.discount_percent||0 %>"></label><% } %>
<label class="span-3">Uwagi<textarea name="notes" rows="3"><%= body.notes||'' %></textarea></label><div class="span-3 notice warning">Po zapisaniu protokół otrzyma nową wersję, a zapisany podpis zostanie cofnięty.</div><div class="span-3 form-actions"><button class="button primary" type="submit">Zapisz zmiany</button></div></form>
<%- include('../partials/footer') %>
