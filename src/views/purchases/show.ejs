<%- include('../partials/header') %>
<div class="page-head"><div><span class="eyebrow"><%= document.supplier_name||'Dostawca' %></span><h1><%= label('purchaseType',document.type) %> <%= document.number %></h1><p><%= formatDate(document.issue_date) %> · <%= document.reference||'bez numeru referencyjnego' %></p></div><button class="button primary" data-open-modal="purchase-item-modal">＋ Dodaj pozycję</button></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Kod / producent</th><th>Nazwa</th><th>Ilość</th><th class="right">Cena netto</th><th>VAT</th><th class="right">Wartość netto</th><th class="right">Wartość brutto</th><th>Przekazanie</th></tr></thead><tbody><% items.forEach(i=>{ const net=i.quantity*i.purchase_price_net,gross=net*(1+i.vat_rate/100); %><tr><td><strong><%= i.supplier_sku||i.manufacturer_sku||'—' %></strong><small><%= i.manufacturer||'' %></small></td><td class="description"><%= i.name %></td><td><%= i.quantity %> <%= i.unit %></td><td class="right"><%= pln(i.purchase_price_net) %></td><td><%= i.vat_rate %>%</td><td class="right"><%= pln(net) %></td><td class="right"><strong><%= pln(gross) %></strong></td><td><div class="row-actions"><form method="post" action="<%= basePath %>/purchase-items/<%= i.id %>/add-stock"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="quantity" value="<%= i.quantity %>"><button class="button small success" <%= i.added_to_stock?'disabled':'' %>><%= i.added_to_stock?'W magazynie':'Do magazynu' %></button></form><button class="button small" data-open-transfer="wz-<%= i.id %>">Do zlecenia</button></div><div class="inline-transfer" id="wz-<%= i.id %>" hidden><form method="post" action="<%= basePath %>/purchase-items/<%= i.id %>/add-order"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="quantity" type="number" value="<%= i.quantity %>" min="0.01" step="0.01"><select name="work_order_id" required><option value="">Wybierz zlecenie</option><% orders.forEach(o=>{ %><option value="<%= o.id %>"><%= o.number %> · <%= o.registration||'bez pojazdu' %> · <%= o.client_name||'bez klienta' %></option><% }) %></select><button class="button small primary">Dodaj</button></form></div></td></tr><% }) %></tbody></table></div><% if(!items.length){ %><div class="empty">Dodaj pozycje z dokumentu WZ lub faktury.</div><% } %></section>
<div class="modal" id="purchase-item-modal" hidden><form class="modal-card" method="post" action="<%= basePath %>/purchases/<%= document.id %>/items"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Pozycja dokumentu</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid"><label>Kod dostawcy<input name="supplier_sku"></label><label>Producent<input name="manufacturer"></label><label>Numer producenta<input name="manufacturer_sku"></label><label class="span-2">Nazwa<input name="name" required></label><label>Ilość<input name="quantity" type="number" step="0.01" min="0.01" value="1"></label><label>Jednostka<select name="unit"><option>szt.</option><option>kpl.</option><option>l</option><option>kg</option></select></label><label>Cena zakupu netto<input name="purchase_price_net" type="number" step="0.01" min="0"></label><label>VAT<select name="vat_rate"><option>23</option><option>8</option><option>5</option><option>0</option></select></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary">Dodaj</button></div></form></div>
<%- include('../partials/footer') %>
