# Katalog instalacji produkcyjnej
APP_DIR=/opt/moj-warsztat

# Repozytorium obrazu bez tagu, np. ghcr.io/twoj-login/moj-warsztat
IMAGE_REPO=ghcr.io/TWOJ_GITHUB_LOGIN/moj-warsztat
IMAGE_TAG=stable

# Lokalny endpoint używany po aktualizacji do testu działania
HEALTH_URL=http://127.0.0.1:3000/health
HEALTH_RETRIES=30
HEALTH_DELAY=2

# Katalog lokalnych kopii przed aktualizacją / ręcznych backupów
LOCAL_BACKUP_DIR=/var/backups/moj-warsztat
LOCAL_BACKUP_KEEP=30
