<%- include('partials/header') %>
<section class="public-card">
  <div class="brand large"><span class="brand-mark">MG</span><span><%= company.name %></span></div>
  <div class="eyebrow">Wycena naprawy</div><h1><%= order.number %></h1>
  <p><strong><%= order.client_name %></strong><br><%= order.registration || '' %> · <%= order.make || '' %> <%= order.model || '' %></p>
  <div class="table-wrap"><table class="data-table" style="min-width:600px"><thead><tr><th>Pozycja</th><th>Ilość</th><th>Brutto</th></tr></thead><tbody><% items.forEach(item => { const t=lineTotals(item); %><tr><td><%= item.description %></td><td><%= item.quantity %> <%= item.unit %></td><td><%= pln(t.gross) %></td></tr><% }) %></tbody></table></div>
  <div class="public-total">Razem: <strong><%= pln(totals.gross) %></strong></div>
  <% if (order.accepted_at) { %><div class="notice success">Wycena została już zaakceptowana.</div><% } else { %>
  <form method="post" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Imię i nazwisko osoby akceptującej<input name="name" required></label><label class="checkbox"><input type="checkbox" name="accepted" value="1" required><span>Akceptuję przedstawiony zakres i koszt prac.</span></label><button class="button primary full" type="submit">Akceptuję wycenę</button></form><% } %>
</section>
<%- include('partials/footer') %>
