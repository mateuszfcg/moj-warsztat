<%- include('../partials/header') %>
<div class="toolbar"><button class="button primary" data-open-modal="task-modal">＋ Nowe zadanie</button><div class="segmented"><a class="<%= status==='open'?'active':'' %>" href="<%= basePath %>/tasks?status=open">Aktywne</a><a class="<%= status==='todo'?'active':'' %>" href="<%= basePath %>/tasks?status=todo">Do zrobienia</a><a class="<%= status==='in_progress'?'active':'' %>" href="<%= basePath %>/tasks?status=in_progress">W trakcie</a><a class="<%= status==='done'?'active':'' %>" href="<%= basePath %>/tasks?status=done">Zakończone</a></div></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Zadanie</th><th>Zlecenie / pojazd</th><th>Planowana data</th><th>Szac. czas</th><th>Priorytet</th><th>Status</th><th></th></tr></thead><tbody>
<% tasks.forEach(task=>{ %><tr><td class="description"><strong><%= task.title %></strong><% if(task.description){ %><small><%= task.description %></small><% } %></td><td><% if(task.work_order_number){ %><a href="<%= basePath %>/orders/<%= task.work_order_id %>"><%= task.work_order_number %></a><small><%= [task.registration,task.make,task.model].filter(Boolean).join(' ') %></small><% }else{ %>—<% } %></td><td><%= formatDate(task.planned_date) %></td><td><%= task.estimated_hours||0 %> h</td><td><span class="priority <%= task.priority %>"><%= task.priority==='urgent'?'Pilne':task.priority==='high'?'Wysoki':task.priority==='low'?'Niski':'Normalny' %></span></td><td><span class="status status-<%= task.status %>"><%= taskStatuses[task.status]||task.status %></span></td><td class="right"><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/status" class="inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><select name="status" onchange="this.form.submit()"><option value="todo" <%= task.status==='todo'?'selected':'' %>>Do zrobienia</option><option value="in_progress" <%= task.status==='in_progress'?'selected':'' %>>W trakcie</option><option value="done" <%= task.status==='done'?'selected':'' %>>Zakończone</option></select></form></td></tr><% }) %>
</tbody></table></div><% if(!tasks.length){ %><div class="empty">Brak zadań w tym widoku.</div><% } %></section>
<div class="modal" id="task-modal" hidden><form class="modal-card" method="post" action="<%= basePath %>/tasks"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Nowe zadanie</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid"><label class="span-2">Nazwa<input name="title" required></label><label class="span-2">Opis<textarea name="description" rows="3"></textarea></label><label>Zlecenie<select name="work_order_id"><option value="">Bez zlecenia</option><% orders.forEach(o=>{ %><option value="<%= o.id %>"><%= o.number %> · <%= o.registration||'bez rej.' %> · <%= o.client_name %></option><% }) %></select></label><label>Przypisane do<select name="assigned_to"><% users.forEach(u=>{ %><option value="<%= u.id %>"><%= u.name %></option><% }) %></select></label><label>Planowana data<input name="planned_date" type="date"></label><label>Szacowany czas [h]<input name="estimated_hours" type="number" step="0.25" min="0" value="1"></label><label>Priorytet<select name="priority"><option value="low">Niski</option><option value="normal" selected>Normalny</option><option value="high">Wysoki</option><option value="urgent">Pilne</option></select></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary">Dodaj zadanie</button></div></form></div>
<%- include('../partials/footer') %>
