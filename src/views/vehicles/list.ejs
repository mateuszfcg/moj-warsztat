<%- include('../partials/header') %>
<div class="toolbar"><button class="button primary" type="button" data-open-modal="vehicle-modal">＋ Dodaj pojazd</button><div class="toolbar-right"><form method="get" class="toolbar"><label class="searchbox"><span>⌕</span><input name="q" value="<%= q %>" placeholder="Rejestracja, VIN, marka, model lub klient"></label><button class="button icon" type="submit">↵</button></form></div></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Pojazd</th><th>Rejestracja</th><th>VIN</th><th>Klient</th><th>Rok</th><th>Przebieg</th></tr></thead><tbody>
<% vehicles.forEach(v=>{ %><tr><td><a class="number-link" href="<%= basePath %>/vehicles/<%= v.id %>"><%= v.make||'Pojazd' %> <%= v.model||'' %></a></td><td><strong><%= v.registration||'—' %></strong></td><td class="mono"><%= v.vin||'—' %></td><td><%= v.client_name %></td><td><%= v.year||'—' %></td><td><%= v.mileage?v.mileage+' km':'—' %></td></tr><% }) %>
</tbody></table></div><% if(!vehicles.length){ %><div class="empty">Nie znaleziono pojazdów.</div><% } %><div class="table-footer"><span><%= vehicles.length %> pojazdów</span></div></section>
<div class="modal" id="vehicle-modal" hidden><form class="modal-card wide" method="post" action="<%= basePath %>/vehicles"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="return_to" value="/vehicles"><div class="modal-head"><h2>Nowy pojazd</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid three"><label class="span-3">Klient<select name="client_id" required><option value="">Wybierz klienta</option><% clients.forEach(c=>{ %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select></label><label>Rejestracja<input name="registration"></label><label class="span-2">VIN<input name="vin" id="vin" maxlength="17"></label><label>Marka<input name="make" id="make"></label><label>Model<input name="model" id="model"></label><label>Rok<input name="year" id="year" type="number"></label><label>Silnik<input name="engine" id="engine"></label><label>Paliwo<input name="fuel" id="fuel"></label><label>Przebieg<input name="mileage" type="number"></label><label>Kolor<input name="color"></label><label class="span-2">Notatki<textarea name="notes" rows="3"></textarea></label></div><div id="vin-result" class="notice hidden" style="margin-top:8px"></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button" id="decode-vin" type="button">Rozpoznaj VIN</button><button class="button primary" type="submit">Zapisz pojazd</button></div></form></div>
<%- include('../partials/footer') %>
