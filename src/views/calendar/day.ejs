<%- include('../partials/header') %>
<% const prev=new Date(date+'T12:00:00');prev.setDate(prev.getDate()-1); const next=new Date(date+'T12:00:00');next.setDate(next.getDate()+1); const iso=d=>d.toISOString().slice(0,10); %>
<div class="calendar-toolbar"><div class="date-nav"><a class="button icon" href="<%= basePath %>/calendar?date=<%= iso(prev) %>">‹</a><a class="button" href="<%= basePath %>/calendar">Dziś</a><a class="button icon" href="<%= basePath %>/calendar?date=<%= iso(next) %>">›</a></div><h1><%= new Date(date+'T12:00:00').toLocaleDateString('pl-PL',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %></h1><button class="button primary" data-open-modal="event-modal">＋ Termin</button></div>
<div class="calendar-layout"><aside class="unscheduled"><div class="card-head"><h2>Nieprzypisane zlecenia</h2><span class="count-pill"><%= unscheduled.length %></span></div><div class="unscheduled-list"><% unscheduled.forEach(o=>{ %><button class="unscheduled-order" data-event-order="<%= o.id %>" data-event-title="<%= o.number %> · <%= o.registration||'' %> · <%= o.client_name %>"><strong><%= o.number %></strong><span><%= o.client_name %></span><small><%= [o.registration,o.make,o.model].filter(Boolean).join(' ') %></small></button><% }) %><% if(!unscheduled.length){ %><p class="muted small">Wszystkie otwarte zlecenia są zaplanowane.</p><% } %></div></aside>
<section class="calendar-board"><div class="calendar-columns" style="--resources:<%= Math.max(1,resources.length) %>"><% resources.forEach(resource=>{ %><div class="calendar-column"><div class="resource-head"><span class="resource-dot" style="background:<%= resource.color %>"></span><strong><%= resource.name %></strong></div><div class="time-grid"><% for(let h=8;h<19;h++){ for(let m of [0,30]){ const hh=String(h).padStart(2,'0'),mm=String(m).padStart(2,'0'); %><button class="time-slot" data-slot-time="<%= date %>T<%= hh %>:<%= mm %>" data-resource-id="<%= resource.id %>"><span><%= hh %>:<%= mm %></span></button><% }} %><% events.filter(e=>e.resource_id===resource.id).forEach(e=>{ const start=new Date(e.starts_at),end=new Date(e.ends_at); const startMinutes=(start.getHours()-8)*60+start.getMinutes(); const duration=Math.max(30,(end-start)/60000); %><article class="calendar-event" style="--top:<%= startMinutes %>;--height:<%= duration %>;border-left-color:<%= resource.color %>"><strong><%= e.title %></strong><span><%= start.toLocaleTimeString('pl-PL',{hour:'2-digit',minute:'2-digit'}) %>–<%= end.toLocaleTimeString('pl-PL',{hour:'2-digit',minute:'2-digit'}) %></span><% if(e.work_order_number){ %><a href="<%= basePath %>/orders/<%= e.work_order_id %>"><%= e.work_order_number %> · <%= e.registration||'' %></a><% } %><form method="post" action="<%= basePath %>/calendar/events/<%= e.id %>/delete" onsubmit="return confirm('Usunąć termin?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button>×</button></form></article><% }) %></div></div><% }) %></div></section></div>
<div class="modal" id="event-modal" hidden><form class="modal-card" method="post" action="<%= basePath %>/calendar/events"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Nowy termin</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid"><label class="span-2">Nazwa<input id="event-title" name="title" required></label><label>Zlecenie<select id="event-order" name="work_order_id"><option value="">Bez zlecenia</option><% orders.forEach(o=>{ %><option value="<%= o.id %>"><%= o.number %> · <%= o.registration||'' %> · <%= o.client_name %></option><% }) %></select></label><label>Stanowisko<select id="event-resource" name="resource_id"><% resources.forEach(r=>{ %><option value="<%= r.id %>"><%= r.name %></option><% }) %></select></label><label>Od<input id="event-start" name="starts_at" type="datetime-local" value="<%= date %>T08:00" required></label><label>Do<input id="event-end" name="ends_at" type="datetime-local" value="<%= date %>T09:00" required></label><label class="span-2">Uwagi<textarea name="notes" rows="3"></textarea></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary">Zapisz termin</button></div></form></div>
<%- include('../partials/footer') %>
