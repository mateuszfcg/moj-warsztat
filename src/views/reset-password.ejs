<%- include('partials/header') %>
<section class="login-card">
  <div class="brand large"><span class="brand-mark">MW</span><span><%= appName %></span></div>
  <h1>Ustaw nowe hasło</h1>
  <p class="muted"><%= email %></p>
  <form method="post" action="<%= basePath %>/reset-password/<%= token %>" class="stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Nowe hasło<input type="password" name="password" minlength="10" required autofocus autocomplete="new-password"></label>
    <button class="button primary full" type="submit">Zapisz nowe hasło</button>
  </form>
</section>
<%- include('partials/footer') %>
