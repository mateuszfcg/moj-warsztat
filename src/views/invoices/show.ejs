<%- include('../partials/header') %>
<div class="page-head"><div><div class="eyebrow"><%= invoice.document_type==='correction'?'Faktura korygująca':invoice.document_type==='invoice_receipt'?'Faktura do paragonu':'Faktura' %></div><h1><%= invoice.number %></h1><p class="muted"><%= invoice.client_name %> · <%= formatDate(invoice.issue_date) %><%= invoice.corrected_number?' · korekta do '+invoice.corrected_number:'' %></p></div><div class="actions"><a class="button" href="<%= basePath %>/invoices/<%= invoice.id %>/edit">Edytuj</a><a class="button" target="_blank" href="<%= basePath %>/invoices/<%= invoice.id %>/pdf">Drukuj / PDF</a><a class="button" href="<%= basePath %>/invoices/<%= invoice.id %>/pdf?download=1">Pobierz</a><% if(invoice.work_order_id){ %><a class="button" href="<%= basePath %>/orders/<%= invoice.work_order_id %>">Zlecenie</a><% } %></div></div>
<div class="invoice-summary"><span class="badge status-<%= invoice.status %>"><%= label('invoice',invoice.status) %></span><span>Rabat: <strong><%= invoice.discount_percent||0 %>%</strong></span><span>Do zapłaty: <strong><%= pln(totals.gross) %></strong></span><span>KSeF: <strong><%= label('ksef',invoice.ksef_status) %></strong></span></div>
<div class="two-col"><section class="card details"><h2>Dane faktury</h2><dl><dt>Data wystawienia</dt><dd><%= formatDate(invoice.issue_date) %></dd><dt>Data sprzedaży</dt><dd><%= formatDate(invoice.sale_date) %></dd><dt>Termin płatności</dt><dd><%= formatDate(invoice.due_date) %></dd><dt>Metoda</dt><dd><%= label('payment',invoice.payment_method) %></dd><dt>Nabywca</dt><dd><%= invoice.client_name %></dd><dt>NIP</dt><dd><%= invoice.client_nip||'—' %></dd><dt>Numer paragonu</dt><dd><%= invoice.receipt_number||'—' %></dd></dl></section>
<section class="card"><h2>Operacje</h2><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/status" class="inline-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><select name="status"><% ['draft','issued','sent','paid','cancelled'].forEach(s=>{ %><option value="<%= s %>" <%= invoice.status===s?'selected':'' %>><%= label('invoice',s) %></option><% }) %></select><button class="button" type="submit">Zmień status</button></form><hr><div class="actions"><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/correction"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button" type="submit">Utwórz korektę</button></form><% if(invoice.status!=='draft'){ %><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/ksef"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button primary" type="submit">Wyślij do KSeF</button></form><% } %></div></section></div>
<section class="card"><h2>Pozycje</h2><div class="table-wrap"><table><thead><tr><th>Opis</th><th>Ilość</th><th>Netto</th><th>VAT</th><th>Brutto</th></tr></thead><tbody><% items.forEach(item=>{ const t=lineTotals(item); %><tr><td><%= item.description %></td><td><%= item.quantity %> <%= item.unit %></td><td><%= pln(t.net) %></td><td><%= item.vat_rate %>% / <%= pln(t.vat) %></td><td><strong><%= pln(t.gross) %></strong></td></tr><% }) %></tbody><tfoot><% if(totals.discountPercent>0){ %><tr><th colspan="4">Rabat <%= totals.discountPercent %>%</th><th>-<%= pln(totals.discountGross) %></th></tr><% } %><tr><th colspan="2">Razem po rabacie</th><th><%= pln(totals.net) %></th><th><%= pln(totals.vat) %></th><th><%= pln(totals.gross) %></th></tr></tfoot></table></div></section>
<div class="two-col"><section class="card"><h2>Wyślij e-mail</h2><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/email" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Adres e-mail<input name="to" type="email" value="<%= invoice.client_email||'' %>"></label><button class="button" type="submit" <%= !smtpConfigured?'disabled':'' %>>Wyślij PDF e-mailem</button><% if(!smtpConfigured){ %><small class="muted">SMTP nie jest skonfigurowane.</small><% } %></form></section><section class="card"><h2>Powiadomienie SMS</h2><form method="post" action="<%= basePath %>/invoices/<%= invoice.id %>/sms" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Numer telefonu<input name="to" value="<%= invoice.client_phone||'' %>"></label><button class="button" type="submit" <%= !smsConfigured?'disabled':'' %>>Wyślij SMS</button><% if(!smsConfigured){ %><small class="muted">Skonfiguruj SMS_WEBHOOK_URL w .env.</small><% } %></form></section></div>
<%- include('../partials/footer') %>
