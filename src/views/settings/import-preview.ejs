<%- include('../partials/header') %>
<div class="page-head"><div><h1>Podgląd importu EPP</h1><p class="muted"><%= filename %></p></div><a class="button" href="<%= basePath %>/settings/import">Anuluj</a></div>
<div class="metric-grid"><div class="metric-card"><span>Dokumenty</span><strong><%= summary.total %></strong></div><% Object.entries(summary.counts||{}).slice(0,5).forEach(([type,count])=>{ %><div class="metric-card"><span><%= type %></span><strong><%= count %></strong></div><% }) %></div>
<section class="card"><div class="card-head"><h2>Próbka danych</h2></div><div class="table-wrap"><table class="data-table"><thead><tr><th>Typ</th><th>Numer</th><th>Kontrahent</th><th>NIP</th><th>Data</th><th class="right">Netto</th><th class="right">Brutto</th></tr></thead><tbody><% sample.forEach(d=>{ %><tr><td><%= d.document_type %></td><td><%= d.document_number||'—' %></td><td><%= d.contractor_name||'—' %></td><td><%= d.contractor_nip||'—' %></td><td><%= d.issue_date||'—' %></td><td class="right"><%= pln(d.net) %></td><td class="right"><%= pln(d.gross) %></td></tr><% }) %></tbody></table></div></section>
<section class="card"><form method="post" action="<%= basePath %>/settings/import/epp/commit"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label class="checkbox-row"><input type="checkbox" name="create_clients" value="1"> Utwórz brakujące kartoteki kontrahentów znalezionych w dokumentach</label><div class="notice warning" style="margin-top:12px">Import zapisze dokumenty w archiwum historycznym. Nie tworzy automatycznie pojazdów ani zleceń bez danych źródłowych, których nie ma w EPP.</div><div class="form-actions"><a class="button" href="<%= basePath %>/settings/import">Wróć</a><button class="button primary" type="submit">Potwierdź import</button></div></form></section>
<%- include('../partials/footer') %>
