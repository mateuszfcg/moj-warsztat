<%- include('../partials/header') %>
<% const permLabels={orders:'Zlecenia',clients:'Klienci',vehicles:'Pojazdy',invoices:'Sprzedaż',reports:'Raporty',tasks:'Zadania',inventory:'Magazyn',settings:'Ustawienia',ksef:'KSeF'}; %>
<div class="page-head"><div><span class="eyebrow">Ustawienia</span><h1>Użytkownicy i pracownicy</h1><p>Role, stanowiska, dostęp do modułów, prowizja i koszt utrzymania pracownika.</p></div><div class="actions"><a class="button" href="<%= basePath %>/settings/positions">Edytuj stanowiska</a><button class="button primary" type="button" data-open-modal="user-new-modal">＋ Nowy użytkownik</button></div></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Użytkownik</th><th>Stanowisko</th><th>Rola</th><th>Prowizja</th><th>Koszt / mies.</th><th>Status</th><th>Ostatnie logowanie</th><th></th></tr></thead><tbody>
<% users.forEach(user => { %><tr><td><strong><%= user.name %></strong><small><%= user.email %><%= user.id===currentUser.id?' · Twoje konto':'' %></small></td><td><%= user.position_name||'—' %></td><td><span class="badge"><%= userRoles[user.role]||user.role %></span></td><td><%= user.commission_percent||0 %>%</td><td><%= pln(user.monthly_cost||0) %></td><td><span class="status-badge <%= user.is_active?'status-completed':'status-cancelled' %>"><%= user.is_active?'Aktywny':'Zablokowany' %></span></td><td><%= user.last_login_at?new Date(user.last_login_at.replace(' ','T')+'Z').toLocaleString('pl-PL'):'Nigdy' %></td><td class="right"><div class="actions"><button class="button small" type="button" data-open-modal="user-edit-<%= user.id %>">Edytuj</button><% if(user.id!==currentUser.id){ %><form method="post" action="<%= basePath %>/settings/users/<%= user.id %>/toggle-active" class="inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button small <%= user.is_active?'danger':'' %>"><%= user.is_active?'Zablokuj':'Odblokuj' %></button></form><% } %></div></td></tr><% }) %>
</tbody></table></div></section>

<div class="modal" id="user-new-modal" hidden><form class="modal-card wide" method="post" action="<%= basePath %>/settings/users"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Nowy użytkownik</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid three"><label>Nazwa<input name="name" required></label><label>E-mail<input type="email" name="email" required></label><label>Hasło startowe<input type="password" name="password" minlength="10" required></label><label>Rola<select name="role"><% Object.entries(userRoles).forEach(([key,labelText])=>{ %><option value="<%= key %>"><%= labelText %></option><% }) %></select></label><label>Stanowisko<select name="position_id"><option value="">Brak</option><% positions.filter(p=>p.active).forEach(p=>{ %><option value="<%= p.id %>"><%= p.name %></option><% }) %></select></label><label>Prowizja %<input name="commission_percent" type="number" step="0.01" min="0" value="0"></label><label>Koszt pracownika / mies.<input name="monthly_cost" type="number" step="0.01" min="0" value="0"></label></div><div class="permission-grid"><% Object.entries(permLabels).forEach(([key,labelText])=>{ %><label class="checkbox"><input type="checkbox" name="permission_<%= key %>" value="1" checked><span><%= labelText %></span></label><% }) %></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary">Dodaj</button></div></form></div>

<% users.forEach(user=>{ %><div class="modal" id="user-edit-<%= user.id %>" hidden><div class="modal-card wide"><div class="modal-head"><h2>Edycja: <%= user.name %></h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><form method="post" action="<%= basePath %>/settings/users/<%= user.id %>" class="stack"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="form-grid three"><label>Nazwa<input name="name" value="<%= user.name %>" required></label><label>E-mail<input type="email" name="email" value="<%= user.email %>" required></label><label>Rola<select name="role"><% Object.entries(userRoles).forEach(([key,labelText])=>{ %><option value="<%= key %>" <%= user.role===key?'selected':'' %>><%= labelText %></option><% }) %></select></label><label>Stanowisko<select name="position_id"><option value="">Brak</option><% positions.forEach(p=>{ %><option value="<%= p.id %>" <%= String(user.position_id||'')===String(p.id)?'selected':'' %>><%= p.name %><%= p.active?'':' (nieaktywne)' %></option><% }) %></select></label><label>Prowizja %<input name="commission_percent" type="number" step="0.01" min="0" value="<%= user.commission_percent||0 %>"></label><label>Koszt / mies.<input name="monthly_cost" type="number" step="0.01" min="0" value="<%= user.monthly_cost||0 %>"></label></div><div class="permission-grid"><% Object.entries(permLabels).forEach(([key,labelText])=>{ %><label class="checkbox"><input type="checkbox" name="permission_<%= key %>" value="1" <%= user.role==='owner'||user.permissions[key]!==false?'checked':'' %>><span><%= labelText %></span></label><% }) %></div><div class="form-actions"><button class="button primary">Zapisz użytkownika</button></div></form><hr><form method="post" action="<%= basePath %>/settings/users/<%= user.id %>/password" class="form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Nowe hasło<input type="password" name="password" minlength="10" required></label><div class="form-actions"><button class="button">Zmień hasło</button></div></form></div></div></div><% }) %>
<%- include('../partials/footer') %>
