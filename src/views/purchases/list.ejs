<%- include('../partials/header') %>
<div class="toolbar"><button class="button primary" data-open-modal="purchase-modal">＋ Dodaj dokument</button><a class="button" href="<%= basePath %>/catalog?tab=wz">Katalog · WZ</a></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Dokument</th><th>Typ</th><th>Dostawca</th><th>Data</th><th>Referencja</th><th class="right">Netto</th><th class="right">Brutto</th><th>Status</th></tr></thead><tbody><% documents.forEach(d=>{ %><tr><td><a href="<%= basePath %>/purchases/<%= d.id %>"><strong><%= d.number %></strong></a></td><td><span class="badge"><%= label('purchaseType',d.type) %></span></td><td><%= d.supplier_name||'—' %></td><td><%= formatDate(d.issue_date) %></td><td><%= d.reference||'—' %></td><td class="right"><%= pln(d.total_net) %></td><td class="right"><strong><%= pln(d.total_gross) %></strong></td><td><span class="status status-ready">Przyjęty</span></td></tr><% }) %></tbody></table></div><% if(!documents.length){ %><div class="empty">Brak dokumentów zakupu i WZ.</div><% } %></section>
<div class="modal" id="purchase-modal" hidden><form class="modal-card" method="post" action="<%= basePath %>/purchases"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Nowy dokument zakupu</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid"><label>Typ<select name="type"><option value="wz">WZ</option><option value="invoice">Faktura zakupu</option><option value="receipt">Paragon</option></select></label><label>Dostawca<select name="supplier_id"><option value="">Inny</option><% suppliers.forEach(s=>{ %><option value="<%= s.id %>"><%= s.name %></option><% }) %></select></label><label>Numer dokumentu<input name="number" placeholder="Puste = numer automatyczny"></label><label>Data<input name="issue_date" type="date" value="<%= new Date().toISOString().slice(0,10) %>"></label><label class="span-2">Numer referencyjny<input name="reference"></label><label class="span-2">Uwagi<textarea name="notes" rows="3"></textarea></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary">Utwórz</button></div></form></div>
<%- include('../partials/footer') %>
