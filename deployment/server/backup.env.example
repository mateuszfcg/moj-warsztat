APP_DIR=/opt/moj-warsztat
LOCAL_BACKUP_DIR=/var/backups/moj-warsztat
LOCAL_BACKUP_KEEP=30

# Opcjonalny zaszyfrowany backup restic. Pozostaw puste, aby używać tylko kopii lokalnych.
# Przykład S3/B2:
# RESTIC_REPOSITORY=s3:s3.eu-central-003.backblazeb2.com/nazwa-bucketu/moj-warsztat
RESTIC_REPOSITORY=
RESTIC_PASSWORD_FILE=/etc/moj-warsztat/restic-password

# Opcjonalne dane backendu S3/B2 (wpisz w /etc/moj-warsztat/backup.env)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Retencja restic
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=12
