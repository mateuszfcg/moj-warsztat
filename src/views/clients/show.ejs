<%- include('../partials/header') %>
<div class="page-head"><div><h1><%= customer.name %></h1><p class="muted"><%= customer.type === 'company' ? 'Firma' : 'Klient indywidualny' %></p></div><div class="actions"><a class="button" href="<%= basePath %>/vehicles/new?client_id=<%= customer.id %>">+ Pojazd</a><a class="button" href="<%= basePath %>/clients/<%= customer.id %>/edit">Edytuj</a></div></div>
<div class="two-col">
<section class="card details"><h2>Dane</h2><dl><dt>NIP</dt><dd><%= customer.nip || '—' %></dd><dt>Telefon</dt><dd><%= customer.phone || '—' %></dd><dt>E-mail</dt><dd><%= customer.email || '—' %></dd><dt>Adres</dt><dd><%= customer.address || '—' %></dd><dt>Notatki</dt><dd><%= customer.notes || '—' %></dd></dl></section>
<section class="card"><div class="card-head"><h2>Pojazdy</h2><a href="<%= basePath %>/vehicles/new?client_id=<%= customer.id %>">Dodaj</a></div><% if (!vehicles.length) { %><p class="empty">Brak pojazdów.</p><% } %><div class="item-list"><% vehicles.forEach(v => { %><a href="<%= basePath %>/vehicles/<%= v.id %>" class="list-item"><span><strong><%= v.registration || 'Bez rejestracji' %></strong><small><%= v.make || '' %> <%= v.model || '' %> <%= v.year || '' %></small></span><span>›</span></a><% }) %></div></section>
</div>
<section class="card"><div class="card-head"><h2>Historia zleceń</h2></div><div class="table-wrap"><table><thead><tr><th>Numer</th><th>Pojazd</th><th>Status</th><th>Data</th></tr></thead><tbody><% orders.forEach(o => { %><tr><td><a href="<%= basePath %>/orders/<%= o.id %>"><%= o.number %></a></td><td><%= o.registration || '—' %> · <%= o.make || '' %> <%= o.model || '' %></td><td><span class="badge status-<%= o.status %>"><%= o.status %></span></td><td><%= formatDate(o.created_at) %></td></tr><% }) %></tbody></table></div><% if (!orders.length) { %><p class="empty">Brak historii.</p><% } %></section>
<section class="card"><div class="card-head"><h2>Faktury</h2></div><div class="table-wrap"><table><thead><tr><th>Numer</th><th>Data</th><th>Status</th><th>KSeF</th></tr></thead><tbody><% invoices.forEach(i => { %><tr><td><a href="<%= basePath %>/invoices/<%= i.id %>"><%= i.number %></a></td><td><%= formatDate(i.issue_date) %></td><td><span class="badge status-<%= i.status %>"><%= i.status %></span></td><td><%= i.ksef_status %></td></tr><% }) %></tbody></table></div></section>
<%- include('../partials/footer') %>
