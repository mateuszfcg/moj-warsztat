<%- include('partials/header') %>
<% const serviceItems=items.filter(i=>['labor','service'].includes(i.type)); const partItems=items.filter(i=>!['labor','service'].includes(i.type)); %>
<section class="public-estimate public-estimate-v2" style="--public-accent:<%= templateSettings.document_accent_color||'#2563eb' %>;--public-head:<%= templateSettings.document_table_header_color||'#e8eef5' %>">
  <div class="public-estimate-hero"><div><div class="brand large"><span class="brand-mark">MW</span><span><%= company.name %></span></div><div class="eyebrow">Kosztorys naprawy do akceptacji</div><h1><%= order.number %></h1><p>Sprawdź zakres prac i koszt. Akceptacja zostanie zapisana z datą i godziną.</p></div><div class="public-estimate-total"><span>Łącznie brutto</span><strong><%= pln(totals.gross) %></strong></div></div>
  <div class="public-meta"><div><span>Klient</span><strong><%= order.client_name||'Klient nieprzypisany' %></strong></div><div><span>Pojazd</span><strong><%= order.vehicle_id?([order.registration,order.make,order.model].filter(Boolean).join(' ')||'Pojazd bez danych'):'Pojazd nieprzypisany' %></strong></div><div><span>Zakres zgłoszenia</span><strong><%= order.complaint||'—' %></strong></div></div>
  <% const renderRows=(rows)=>{ %><% rows.forEach(item=>{ const t=lineTotals(item); %><tr><td><strong><%= item.description %></strong><% if(item.discount_percent){ %><small>Rabat pozycji: <%= item.discount_percent %>%</small><% } %></td><td><%= item.quantity %> <%= item.unit %></td><td><%= pln(t.net) %></td><td><%= item.vat_rate %>%</td><td><strong><%= pln(t.gross) %></strong></td></tr><% }) %><% }; %>
  <% if(serviceItems.length){ %><h2 class="public-section-title">Usługi i robocizna</h2><div class="table-wrap"><table class="data-table public-estimate-table"><thead><tr><th>Pozycja</th><th>Ilość</th><th>Netto po rabacie</th><th>VAT</th><th>Brutto</th></tr></thead><tbody><% renderRows(serviceItems); %></tbody></table></div><% } %>
  <% if(partItems.length){ %><h2 class="public-section-title">Części i materiały</h2><div class="table-wrap"><table class="data-table public-estimate-table"><thead><tr><th>Pozycja</th><th>Ilość</th><th>Netto po rabacie</th><th>VAT</th><th>Brutto</th></tr></thead><tbody><% renderRows(partItems); %></tbody></table></div><% } %>
  <div class="public-totals"><% if(totals.lineDiscountNet>0){ %><div><span>Rabaty na pozycjach netto</span><strong>-<%= pln(totals.lineDiscountNet) %></strong></div><% } %><div><span>Razem netto</span><strong><%= pln(totals.net) %></strong></div><div><span>VAT</span><strong><%= pln(totals.vat) %></strong></div><div class="grand"><span>Razem brutto</span><strong><%= pln(totals.gross) %></strong></div></div>
  <% if(order.accepted_at){ %><div class="notice success public-result">✓ Wycena została zaakceptowana <%= formatDate(order.accepted_at) %>.</div><% } else { %><form method="post" class="stack public-accept-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label>Imię i nazwisko osoby akceptującej<input name="name" required autocomplete="name"></label><label class="checkbox"><input type="checkbox" name="accepted" value="1" required><span>Akceptuję przedstawiony zakres prac oraz końcowy koszt naprawy.</span></label><button class="button primary full public-accept-button" type="submit">✓ Akceptuję kosztorys</button></form><% } %>
  <p class="public-footer-note">Dokument wygenerowany przez <%= appName %>. W razie pytań skontaktuj się z warsztatem: <%= company.phone||'' %> <%= company.email||'' %></p>
</section>
<%- include('partials/footer') %>
