<%- include('../partials/header') %>
<div class="toolbar"><button class="button primary" data-open-modal="storage-modal">＋ Przyjmij do przechowalni</button></div>
<section class="data-panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Klient</th><th>Pojazd</th><th>Rodzaj / opis</th><th>Sezon</th><th>Lokalizacja</th><th>Przyjęto</th><th>Status</th><th></th></tr></thead><tbody><% items.forEach(i=>{ %><tr><td><strong><%= i.client_name %></strong></td><td><%= [i.registration,i.make,i.model].filter(Boolean).join(' ')||'—' %></td><td class="description"><strong><%= i.type==='tyres'?'Opony / koła':i.type %></strong><small><%= i.description %></small></td><td><%= i.season||'—' %></td><td><%= i.location||'—' %></td><td><%= formatDate(i.accepted_on) %></td><td><span class="status <%= i.status==='stored'?'status-ready':'status-done' %>"><%= i.status==='stored'?'W przechowalni':'Wydano' %></span></td><td><% if(i.status==='stored'){ %><form method="post" action="<%= basePath %>/storage/<%= i.id %>/release"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="released_on" value="<%= new Date().toISOString().slice(0,10) %>"><button class="button small">Wydaj</button></form><% } %></td></tr><% }) %></tbody></table></div><% if(!items.length){ %><div class="empty">Przechowalnia jest pusta.</div><% } %></section>
<div class="modal" id="storage-modal" hidden><form class="modal-card" method="post" action="<%= basePath %>/storage"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="modal-head"><h2>Przyjęcie do przechowalni</h2><button class="modal-close" type="button" data-close-modal>×</button></div><div class="modal-body"><div class="form-grid"><label>Klient<select id="storage-client" name="client_id" required><option value="">Wybierz</option><% clients.forEach(c=>{ %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select></label><label>Pojazd<select id="storage-vehicle" name="vehicle_id"><option value="">Bez pojazdu</option><% vehicles.forEach(v=>{ %><option value="<%= v.id %>" data-client-id="<%= v.client_id %>"><%= v.registration||'bez rej.' %> · <%= [v.make,v.model].filter(Boolean).join(' ') %></option><% }) %></select></label><label>Rodzaj<select name="type"><option value="tyres">Opony / koła</option><option value="parts">Części</option><option value="other">Inne</option></select></label><label>Sezon<select name="season"><option value="">—</option><option>Zima</option><option>Lato</option><option>Całoroczne</option></select></label><label class="span-2">Opis<input name="description" required placeholder="np. 4 koła 225/45 R17, felgi aluminiowe"></label><label>Lokalizacja<input name="location" placeholder="np. Regał A3"></label><label>Data przyjęcia<input name="accepted_on" type="date" value="<%= new Date().toISOString().slice(0,10) %>"></label><label class="span-2">Uwagi<textarea name="notes" rows="3"></textarea></label></div></div><div class="modal-foot"><button class="button" type="button" data-close-modal>Anuluj</button><button class="button primary">Przyjmij</button></div></form></div>
<%- include('../partials/footer') %>
