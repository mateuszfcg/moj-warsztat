<%- include('../partials/header') %>
<div class="page-head">
  <div><h1>Raporty</h1><p class="muted">Wybierz zakres dat i wygeneruj raport do podglądu, PDF lub Excela.</p></div>
</div>
<section class="card report-filter">
  <form method="get" action="<%= basePath %>/reports" class="toolbar" style="margin:0">
    <label>Od<input type="date" name="from" value="<%= from %>"></label>
    <label>Do<input type="date" name="to" value="<%= to %>"></label>
    <button class="button primary" type="submit">Pokaż raport</button>
    <a class="button" target="_blank" href="<%= basePath %>/reports/print?from=<%= encodeURIComponent(from) %>&to=<%= encodeURIComponent(to) %>">Otwórz w nowym oknie</a>
    <a class="button" target="_blank" href="<%= basePath %>/reports/pdf?from=<%= encodeURIComponent(from) %>&to=<%= encodeURIComponent(to) %>">Otwórz PDF</a>
    <a class="button" href="<%= basePath %>/reports/pdf?from=<%= encodeURIComponent(from) %>&to=<%= encodeURIComponent(to) %>&download=1">Pobierz PDF</a>
    <a class="button success" href="<%= basePath %>/reports/excel?from=<%= encodeURIComponent(from) %>&to=<%= encodeURIComponent(to) %>">Pobierz Excel</a>
  </form>
</section>
<div class="metric-grid four"><div class="metric-card"><span>Sprzedaż netto</span><strong><%= pln(revenue.net) %></strong><small>Brutto: <%= pln(revenue.gross) %></small></div><div class="metric-card"><span>Marża zleceń netto</span><strong><%= pln(orderProfit.sales_net-orderProfit.cost_net) %></strong><small>Sprzedaż <%= pln(orderProfit.sales_net) %> · koszt <%= pln(orderProfit.cost_net) %></small></div><div class="metric-card"><span>Zakupy netto</span><strong><%= pln(purchases.net) %></strong></div><div class="metric-card"><span>Towary poniżej minimum</span><strong><%= lowStock.length %></strong></div></div>
<div class="two-col"><section class="card"><div class="card-head"><h2>Statusy zleceń</h2></div><table><thead><tr><th>Status</th><th class="right">Liczba</th></tr></thead><tbody><% orderStatus.forEach(r=>{ %><tr><td><%= label('order',r.status) %></td><td class="right"><strong><%= r.count %></strong></td></tr><% }) %></tbody></table><% if(!orderStatus.length){ %><p class="muted">Brak zleceń w wybranym zakresie.</p><% } %></section><section class="card"><div class="card-head"><h2>Niski stan magazynowy</h2></div><table><thead><tr><th>Towar</th><th class="right">Stan / minimum</th></tr></thead><tbody><% lowStock.forEach(p=>{ %><tr><td><%= p.name %></td><td class="right"><strong><%= p.stock_qty %> / <%= p.min_stock %></strong></td></tr><% }) %></tbody></table><% if(!lowStock.length){ %><p class="muted">Brak ostrzeżeń magazynowych.</p><% } %></section></div>
<section class="card"><div class="card-head"><h2>Faktury w zakresie <%= from %> - <%= to %></h2></div><div class="table-wrap"><table><thead><tr><th>Numer</th><th>Data</th><th>Klient</th><th class="right">Netto</th><th class="right">VAT</th><th class="right">Brutto</th><th>Status</th></tr></thead><tbody><% invoices.forEach(i=>{ %><tr><td><strong><%= i.number %></strong></td><td><%= formatDate(i.issue_date) %></td><td><%= i.client_name||'Bez klienta' %></td><td class="right"><%= pln(i.net) %></td><td class="right"><%= pln(i.vat) %></td><td class="right"><strong><%= pln(i.gross) %></strong></td><td><%= label('invoice',i.status) %></td></tr><% }) %></tbody></table></div><% if(!invoices.length){ %><p class="muted">Brak faktur w wybranym zakresie.</p><% } %></section>
<%- include('../partials/footer') %>
